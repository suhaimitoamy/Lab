//@version=5
indicator("ICT Concepts [amygmgo]", max_lines_count=500, max_boxes_count=500, max_labels_count=500, max_bars_back=3000, overlay=true)
//-----------------------------------------------------------------------------}
//Strings
//-----------------------------------------------------------------------------{
o          = 'Options'
sp1        = '       '
sp2        = '              '
hl         = 'High / Low    ' + sp1
ny_        = 'New York'       + sp1
lo_        = 'London Open'
lc_        = 'London Close'
as_        = 'Asian'      

//-----------------------------------------------------------------------------}
//Settings
//-----------------------------------------------------------------------------{
i_mode     = input.string(         'Present'      , title = 'Mode'                   , options =['Present', 'Historical']                                              )

//Market Structure Shift
showMS     = input.bool  (           true         , title = ''                       ,   group = 'Market Structures', inline = 'MS'                                    )
len        = input.int   (             5          , title = '     Length   ' +sp2    ,   group = 'Market Structures', inline = 'MS'       , minval = 3, maxval =  10   )

iMSS       = input.bool  (           true         , title = '       MSS'     +sp1    ,   group = 'Market Structures', inline = 'M1'                                    )
cMSSbl     = input.color (color.new(#00e6a1,  0), title = 'bullish'                ,   group = 'Market Structures', inline = 'M1'                                    )
cMSSbr     = input.color (color.new(#e60400,  0), title = 'bearish'                ,   group = 'Market Structures', inline = 'M1'                                    )

iBOS       = input.bool  (           true         , title = '       BOS'     +sp1    ,   group = 'Market Structures', inline = 'BS'                                    )
cBOSbl     = input.color (color.new(#00e6a1,  0), title = 'bullish'                ,   group = 'Market Structures', inline = 'BS'                                    )
cBOSbr     = input.color (color.new(#e60400,  0), title = 'bearish'                ,   group = 'Market Structures', inline = 'BS'                                    )

//Displacement
sDispl     = input.bool  (           false        , title = 'Show Displacement'      ,   group = 'Displacement'                                                        )

perc_Body  = 0.36 // input.int(   36, minval=1, maxval=36) / 100
bxBack     = 10   // input.int(   10, minval=0, maxval=10)

sVimbl     = input.bool  (           true         , title = ''                       ,   group = 'Volume Imbalance' , inline = 'VI'                                    )
visVim     = input.int   (             2          , title = "   # Visible VI's  "+sp1,   group = 'Volume Imbalance' , inline = 'VI'      , minval = 2, maxval = 100    ) 
cVimbl     = input.color (color.new(#06b2d0,  0), title = ''                       ,   group = 'Volume Imbalance' , inline = 'VI'                                    )

//Order Blocks  
showOB     = input.bool  (           true         , title = 'Show Order Blocks'      ,   group = 'Order Blocks'                                                        )
length     = input.int   (            10          , title = 'Swing Lookback'         ,   group = 'Order Blocks'                          , minval = 3                  )
showBull   = input.int   (             1          , title = 'Show Last Bullish OB'   ,   group = 'Order Blocks'                          , minval = 0                  )
showBear   = input.int   (             1          , title = 'Show Last Bearish OB'   ,   group = 'Order Blocks'                          , minval = 0                  )
useBody    = input.bool  (           true         , title = 'Use Candle Body'                                                                                          )

//OB Style
bullCss    = input.color (color.new(#3e89fa,  0), title = 'Bullish OB  '           ,   group = 'Order Blocks'     , inline = 'bullcss'                               )
bullBrkCss = input.color (color.new(#4785f9, 85), title = 'Bullish Break  '        ,   group = 'Order Blocks'     , inline = 'bullcss'                               )

bearCss    = input.color (color.new(#FF3131,  0), title = 'Bearish OB'             ,   group = 'Order Blocks'     , inline = 'bearcss'                               )
bearBrkCss = input.color (color.new(#f9ff57, 85), title = 'Bearish Break'          ,   group = 'Order Blocks'     , inline = 'bearcss'                               )

showLabels = input.bool  (          false, title = 'Show Historical Polarity Changes',   group = 'Order Blocks'                                                        )

//Liquidity   
showLq     = input.bool  (           true         , title = 'Show Liquidity'         ,   group = 'Liquidity'                                                           )
a     = 10 / input.float (             4          , title = 'margin'                 ,   group = 'Liquidity'   , step = 0.1, minval = 2, maxval =   7                  )
visLiq     = input.int   (             2          , title = '# Visible Liq. boxes'   ,   group = 'Liquidity'
           ,                                       minval = 1         , maxval = 50  , tooltip = 'In the same direction'                                               )
cLIQ_B     = input.color (color.new(#fa451c,  0), title = 'Buyside Liquidity  '    ,   group = 'Liquidity'                                                           )
cLIQ_S     = input.color (color.new(#1ce4fa,  0), title = 'Sellside Liquidity'     ,   group = 'Liquidity'                                                           )

//FVG      
shwFVG     = input.bool  (           true         , title = 'Show FVGs'              ,   group = 'Fair Value Gaps'                                                     )
i_BPR      = input.bool  (           false        , title = 'Balance Price Range'    ,   group = 'Fair Value Gaps'                                                     )
i_FVG      = input.string(           'FVG'        , title = o                        ,   group = 'Fair Value Gaps'  , options=['FVG', 'IFVG']                           
           ,                                                                           tooltip = 'Fair Value Gaps\nor\nImplied Fair Value Gaps'                        )
visBxs     = input.int   (             2          , title = '# Visible FVG\'s'       ,   group = 'Fair Value Gaps'
           ,                                       minval = 1         , maxval = 20  , tooltip = 'In the same direction'                                               )

//FVG Style
cFVGbl     = input.color (color.new(#00e676,  0), title = 'Bullish FVG  '          ,   group = 'Fair Value Gaps'  , inline = 'FVGbl'                                 )
cFVGblBR   = input.color (color.new(#808000,  0), title = 'Break'                  ,   group = 'Fair Value Gaps'  , inline = 'FVGbl'                                 )
cFVGbr     = input.color (color.new(#ff5252,  0), title = 'Bearish FVG '           ,   group = 'Fair Value Gaps'  , inline = 'FVGbr'                                 )
cFVGbrBR   = input.color (color.new(#FF0000,  0), title = 'Break'                  ,   group = 'Fair Value Gaps'  , inline = 'FVGbr'                                 )

//NWOG/NDOG 
iNWOG      = input.bool  (           true         , title = ''        , inline='NWOG',   group = 'NWOG/NDOG'                                                           )
cNWOG1     = input.color (color.new(#ff5252, 28), title = 'NWOG    ', inline='NWOG',   group = 'NWOG/NDOG'                                                           )
cNWOG2     = input.color (color.new(#b2b5be, 50), title = ''        , inline='NWOG',   group = 'NWOG/NDOG'                                                           )
maxNWOG    = input.int   (             3          , title = 'Show max', inline='NWOG',   group = 'NWOG/NDOG'                , minval = 0, maxval =  50                 )

iNDOG      = input.bool  (           false        , title = ''        , inline='NDOG',   group = 'NWOG/NDOG'                                                           )
cNDOG1     = input.color (color.new(#ff9800, 20), title = 'NDOG    ', inline='NDOG',   group = 'NWOG/NDOG'                                                           )
cNDOG2     = input.color (color.new(#4dd0e1, 65), title =    ''     , inline='NDOG',   group = 'NWOG/NDOG'                                                           )
maxNDOG    = input.int   (             1          , title = 'Show max', inline='NDOG',   group = 'NWOG/NDOG'                , minval = 0, maxval =  50                 )

//Fibonacci 
iFib       = input.string(           'NONE'      , title = 'Fibonacci between last: ',   group = 'Fibonacci', options=['FVG', 'BPR', 'OB', 'Liq', 'VI', 'NWOG', 'NONE'])
iExt       = input.bool  (           false       , title = 'Extend lines'            ,   group = 'Fibonacci'                                                           )

//Killzones 
showKZ     = input.bool  (           false        , title = 'Show Killzones'         ,   group = 'Killzones'                                                           )
//New York
showNy     = input.bool  (           true         , title = ny_      , inline = 'ny' ,   group = 'Killzones'                                                           ) and showKZ
nyCss      = input.color (color.new(#ff5d00, 93), title = ''       , inline = 'ny' ,   group = 'Killzones'                                                           )
//London Open
showLdno   = input.bool  (           true         , title = lo_      , inline = 'lo' ,   group = 'Killzones'                                                           ) and showKZ
ldnoCss    = input.color (color.new(#00bcd4, 93), title = ''       , inline = 'lo' ,   group = 'Killzones'                                                           )
//London Close
showLdnc   = input.bool  (           true         , title = lc_      , inline = 'lc' ,   group = 'Killzones'                                                           ) and showKZ
ldncCss    = input.color (color.new(#2157f3, 93), title = ''       , inline = 'lc' ,   group = 'Killzones'                                                           )
//Asian
showAsia   = input.bool  (           true         , title = as_ + sp2, inline = 'as' ,   group = 'Killzones'                                                           ) and showKZ
asiaCss    = input.color (color.new(#e91e63, 93), title = ''       , inline = 'as' ,   group = 'Killzones'                                                           )

//-----------------------------------------------------------------------------}
//Asia High / Low
//-----------------------------------------------------------------------------{
amyAsiaHL_group = "AMY Asia High / Low"
amyAsiaHL_show = input.bool(true, "Show Asia High / Low", group=amyAsiaHL_group)
amyAsiaHL_timezone = input.string("Asia/Makassar", "Timezone", group=amyAsiaHL_group)
amyAsiaHL_session = input.session("0600-1400", "Asia Session", group=amyAsiaHL_group)

amyAsiaHL_inSession = not na(time(timeframe.period, amyAsiaHL_session, amyAsiaHL_timezone))
amyAsiaHL_prevSession = bar_index > 0 ? amyAsiaHL_inSession[1] : false
amyAsiaHL_sessionStart = amyAsiaHL_inSession and not amyAsiaHL_prevSession

var float amyAsiaHL_high = na
var float amyAsiaHL_low = na
var int amyAsiaHL_startBar = na
var line amyAsiaHL_highLine = na
var line amyAsiaHL_lowLine = na
var label amyAsiaHL_highLabel = na
var label amyAsiaHL_lowLabel = na

if amyAsiaHL_sessionStart
    amyAsiaHL_high := high
    amyAsiaHL_low := low
    amyAsiaHL_startBar := bar_index
    if not na(amyAsiaHL_highLine)
        line.delete(amyAsiaHL_highLine)
        amyAsiaHL_highLine := na
    if not na(amyAsiaHL_lowLine)
        line.delete(amyAsiaHL_lowLine)
        amyAsiaHL_lowLine := na
    if not na(amyAsiaHL_highLabel)
        label.delete(amyAsiaHL_highLabel)
        amyAsiaHL_highLabel := na
    if not na(amyAsiaHL_lowLabel)
        label.delete(amyAsiaHL_lowLabel)
        amyAsiaHL_lowLabel := na
else if amyAsiaHL_inSession
    amyAsiaHL_high := na(amyAsiaHL_high) ? high : math.max(amyAsiaHL_high, high)
    amyAsiaHL_low := na(amyAsiaHL_low) ? low : math.min(amyAsiaHL_low, low)

if amyAsiaHL_show and not na(amyAsiaHL_high) and not na(amyAsiaHL_low)
    amyAsiaHL_left = na(amyAsiaHL_startBar) ? bar_index : amyAsiaHL_startBar
    if na(amyAsiaHL_highLine)
        amyAsiaHL_highLine := line.new(amyAsiaHL_left, amyAsiaHL_high, bar_index + 1, amyAsiaHL_high, extend=extend.right, color=color.new(color.purple, 10), width=1)
    if na(amyAsiaHL_lowLine)
        amyAsiaHL_lowLine := line.new(amyAsiaHL_left, amyAsiaHL_low, bar_index + 1, amyAsiaHL_low, extend=extend.right, color=color.new(color.purple, 10), width=1)
    line.set_xy1(amyAsiaHL_highLine, amyAsiaHL_left, amyAsiaHL_high)
    line.set_xy2(amyAsiaHL_highLine, bar_index + 1, amyAsiaHL_high)
    line.set_xy1(amyAsiaHL_lowLine, amyAsiaHL_left, amyAsiaHL_low)
    line.set_xy2(amyAsiaHL_lowLine, bar_index + 1, amyAsiaHL_low)
    if na(amyAsiaHL_highLabel)
        amyAsiaHL_highLabel := label.new(bar_index + 3, amyAsiaHL_high, "ASIA HIGH", style=label.style_label_left, color=color.rgb(96, 74, 128), textcolor=color.white, size=size.tiny)
    if na(amyAsiaHL_lowLabel)
        amyAsiaHL_lowLabel := label.new(bar_index + 3, amyAsiaHL_low, "ASIA LOW", style=label.style_label_left, color=color.rgb(96, 74, 128), textcolor=color.white, size=size.tiny)
    label.set_xy(amyAsiaHL_highLabel, bar_index + 3, amyAsiaHL_high)
    label.set_xy(amyAsiaHL_lowLabel, bar_index + 3, amyAsiaHL_low)
else if not amyAsiaHL_show
    if not na(amyAsiaHL_highLine)
        line.delete(amyAsiaHL_highLine)
        amyAsiaHL_highLine := na
    if not na(amyAsiaHL_lowLine)
        line.delete(amyAsiaHL_lowLine)
        amyAsiaHL_lowLine := na
    if not na(amyAsiaHL_highLabel)
        label.delete(amyAsiaHL_highLabel)
        amyAsiaHL_highLabel := na
    if not na(amyAsiaHL_lowLabel)
        label.delete(amyAsiaHL_lowLabel)
        amyAsiaHL_lowLabel := na

//-----------------------------------------------------------------------------}
//General Calculations
//-----------------------------------------------------------------------------{
n          =                      bar_index
hi         =                      high  
lo         =                      low   
tf_msec    = timeframe.in_seconds(timeframe.period) * 1000
maxSize    =        50
atr        = ta.atr(10)
per        = i_mode == 'Present' ? last_bar_index - bar_index <=  500 : true
perB       = last_bar_index - bar_index <= 1000  ? true : false
xloc       = iFib   ==   'OB'    ? xloc.bar_time : xloc.bar_index
ext        = iExt                ?  extend.right : extend.none
plus       = iFib   ==   'OB'    ?  tf_msec * 50 : 50
mx         = math.max(close , open)
mn         = math.min(close , open)
body       = math.abs(close - open)
meanBody   = ta.sma  (body  ,  len)
max        = useBody ?  mx  : high
min        = useBody ?  mn  : low
blBrkConf  = 0
brBrkConf  = 0
r          = color.r(chart.bg_color)
g          = color.g(chart.bg_color)
b          = color.b(chart.bg_color)
isDark     = r < 80 and g < 80 and b < 80

//-----------------------------------------------------------------------------}
//User Defined Types
//-----------------------------------------------------------------------------{
type ZZ 
    int   [] d
    int   [] x 
    float [] y 
    bool  [] b

type ln_d
    line  l
    int   d

type _2ln_lb
    line  l1
    line  l2
    label lb

type bx_ln
    box   b 
    line  l 

type bx_ln_lb
    box   bx
    line  ln
    label lb 

type mss 
    int     dir
    line [] l_mssBl
    line [] l_mssBr
    line [] l_bosBl
    line [] l_bosBr
    label[] lbMssBl
    label[] lbMssBr
    label[] lbBosBl
    label[] lbBosBr

type liq
    box   bx
    bool  broken
    bool  brokenTop
    bool  brokenBtm
    line  ln

type ob
    float   top       = na
    float   btm       = na
    int     loc       = bar_index
    bool    breaker   = false
    int     break_loc = na

type swing
    float y = na
    int   x = na
    bool  crossed = false

type FVG 
    box box 
    bool active
    int  pos 

var mss MSS = mss.new(
 0
 , array.new < line  >()
 , array.new < line  >() 
 , array.new < line  >()
 , array.new < line  >()
 , array.new < label >() 
 , array.new < label >()
 , array.new < label >()
 , array.new < label >()
 )

//-----------------------------------------------------------------------------}
//Variables
//-----------------------------------------------------------------------------{
maxVimb = 2

var float friCp = na, var int friCi = na // Friday Close price/index
var float monOp = na, var int monOi = na // Monday Open  price/index

var float prDCp = na, var int prDCi = na // Previous Day Open price/index
var float cuDOp = na, var int cuDOi = na // Current  Day Open price/index

var _2ln_lb [] Vimbal     = array.new<  _2ln_lb >() 

var   liq   [] b_liq_B    = array.new<    liq   >(1, liq.new(box(na), false, false, false, line(na)))
var   liq   [] b_liq_S    = array.new<    liq   >(1, liq.new(box(na), false, false, false, line(na)))

var    ob   [] bullish_ob = array.new<    ob    >()
var    ob   [] bearish_ob = array.new<    ob    >()

var bx_ln   [] bl_NWOG    = array.new<   bx_ln  >()
var bx_ln   [] bl_NDOG    = array.new<   bx_ln  >()

var bx_ln_lb[] a_bx_ln_lb = array.new< bx_ln_lb >()

var FVG     [] bFVG_UP    = array.new<    FVG   >()
var FVG     [] bFVG_DN    = array.new<    FVG   >()

var FVG     [] bBPR_UP    = array.new<    FVG   >()
var FVG     [] bBPR_DN    = array.new<    FVG   >()

var  ZZ         aZZ       = 
 ZZ.new(
 array.new < int    >(maxSize,  0), 
 array.new < int    >(maxSize,  0), 
 array.new < float  >(maxSize, na),
 array.new < bool   >(maxSize, na))

var line _diag = line.new(na, na, na, na, color=color.new(color.silver, 50), style=line.style_dashed, xloc= xloc            )
var line _vert = line.new(na, na, na, na, color=color.new(color.silver, 50), style=line.style_dotted, xloc= xloc            )
var line _zero = line.new(na, na, na, na, color=color.new(color.silver,  5), style=line.style_solid , xloc= xloc, extend=ext)
var line _0236 = line.new(na, na, na, na, color=color.new(color.orange, 25), style=line.style_solid , xloc= xloc, extend=ext)
var line _0382 = line.new(na, na, na, na, color=color.new(color.yellow, 25), style=line.style_solid , xloc= xloc, extend=ext)
var line _0500 = line.new(na, na, na, na, color=color.new(color.green , 25), style=line.style_solid , xloc= xloc, extend=ext)
var line _0618 = line.new(na, na, na, na, color=color.new(color.yellow, 25), style=line.style_solid , xloc= xloc, extend=ext)
var line _0786 = line.new(na, na, na, na, color=color.new(color.orange, 25), style=line.style_solid , xloc= xloc, extend=ext)
var line _one_ = line.new(na, na, na, na, color=color.new(color.silver,  5), style=line.style_solid , xloc= xloc, extend=ext)
var line _1618 = line.new(na, na, na, na, color=color.new(color.yellow, 25), style=line.style_solid , xloc= xloc, extend=ext)
 
//-----------------------------------------------------------------------------}
//Functions/methods
//-----------------------------------------------------------------------------{
method in_out(ZZ aZZ, int d, int x1, float y1, int x2, float y2, color col, bool b) =>
    aZZ.d.unshift(d), aZZ.x.unshift(x2), aZZ.y.unshift(y2), aZZ.b.unshift(b), aZZ.d.pop(), aZZ.x.pop(), aZZ.y.pop(), aZZ.b.pop()

method timeinrange(string res, string sess) => not na(time(timeframe.period, res, sess))

method setLine(line ln, int x1, float y1, int x2, float y2) => ln.set_xy1(x1, y1), ln.set_xy2(x2, y2)

method clear_aLine(line[] l) =>
    if l.size() > 0
        for i = l.size() -1 to 0
            l.pop().delete()

method clear_aLabLin(label[] l) =>
    if l.size() > 0
        for i = l.size() -1 to 0
            l.pop().delete()

method clear_aLabLin(line[] l) =>
    if l.size() > 0
        for i = l.size() -1 to 0
            l.pop().delete()

method notransp(color css) => color.rgb(color.r(css), color.g(css), color.b(css))

method display(ob id, css, break_css, str)=>
    if showOB
        if id.breaker
            a_bx_ln_lb.unshift(
             bx_ln_lb.new(
               box.new(id.loc, id.top, timenow + (tf_msec * 10), id.btm, na 
             , bgcolor = break_css
             , extend  = extend.none
             , xloc    = xloc.bar_time)
             , line (na)
             , label(na))
             )
        else
            y  = str == 'bl' ? id.btm : id.top
            s  = str == 'bl' ? label.style_label_up : label.style_label_down
            a_bx_ln_lb.unshift(
             bx_ln_lb.new(
               box(na)
             , line.new(id.loc,   y  , id.loc  + (tf_msec * 10),    y  
             , xloc    = xloc.bar_time, color=css, width=2)
             , label.new(              id.loc  + (tf_msec * 10),    y
             , text  = str == 'bl' ? '+OB' : '-OB'
             , xloc  = xloc.bar_time
             , style = s    , color = color(na)
             , textcolor=css, size  = size.small))
             )

swings(len)=>
    var os = 0
    var swing top = swing.new(na, na)
    var swing btm = swing.new(na, na)
    
    upper = ta.highest(len)
    lower = ta.lowest(len)

    os := high[len] > upper ? 0 
       :  low [len] < lower ? 1 : os

    if os == 0 and os[1] != 0
        top := swing.new(high[length], bar_index[length])
    
    if os == 1 and os[1] != 1
        btm := swing.new(low[length], bar_index[length])

    [top, btm]
            
set_lab(i, str) =>
    style = str == 'Bl' ? label.style_label_down : label.style_label_up
    txcol = str == 'Bl' ? color.lime : color.red
    label.new(math.round(math.avg(aZZ.x.get(i), n)), aZZ.y.get(i), text='BOS'
     , style=style, color=color(na), textcolor=txcol, size=size.tiny)
set_lin(i, str) =>
    color = str == 'Bl' ? color.lime : color.red
    line.new(aZZ.x.get(i), aZZ.y.get(i), n, aZZ.y.get(i), color=color, style=line.style_dotted)

draw(left, col) =>
    //
    max_bars_back(time, 1000)
    var int dir= na, var int x1= na, var float y1= na, var int x2= na, var float y2= na
    //
    sz       = aZZ.d.size( )
    x2      := bar_index -1
    ph       = ta.pivothigh(hi, left, 1)
    pl       = ta.pivotlow (lo, left, 1)
    if ph   
        dir := aZZ.d.get (0) 
        x1  := aZZ.x.get (0) 
        y1  := aZZ.y.get (0) 
        y2  :=      nz(hi[1])
        //
        if dir <  1  // if previous point was a pl, add, and change direction ( 1)
            aZZ.in_out( 1, x1, y1, x2, y2, col, true)
        else
            if dir ==  1 and ph > y1 
                aZZ.x.set(0, x2), aZZ.y.set(0, y2)
        //
        // liquidity
        if showLq and per and sz > 0
            count = 0
            st_P  = 0.
            st_B  = 0
            minP  = 0.
            maxP  = 10e6
            for i = 0 to math.min(sz, 50) -1
                if aZZ.d.get(i) ==  1 
                    if aZZ.y.get(i) > ph + (atr/a)
                        break
                    else
                        if aZZ.y.get(i) > ph - (atr/a) and aZZ.y.get(i) < ph + (atr/a)
                            count += 1
                            st_B := aZZ.x.get(i)
                            st_P := aZZ.y.get(i)
                            if aZZ.y.get(i) > minP
                                minP := aZZ.y.get(i)
                            if aZZ.y.get(i) < maxP 
                                maxP := aZZ.y.get(i)
            if count > 2
                getB = b_liq_B.get(0)
                if st_B == getB.bx.get_left()
                    getB.bx.set_top(math.avg(minP, maxP) + (atr/a))
                    getB.bx.set_rightbottom(n +10, math.avg(minP, maxP) - (atr/a))
                else
                    b_liq_B.unshift(liq.new(
                     box.new(
                       st_B, math.avg(minP, maxP) + (atr/a), n +10, math.avg(minP, maxP) - (atr/a)
                     , text = 'Buyside liquidity', text_size = size.tiny, text_halign = text.align_left
                     , text_valign = text.align_bottom, text_color = color.new(cLIQ_B, 25)
                     , bgcolor=color(na), border_color=color(na)
                      )
                     , false
                     , false
                     , false
                     , line.new(st_B, st_P, n -1, st_P, color = color.new(cLIQ_B, 0))
                      )
                     )      
                if b_liq_B.size() > visLiq
                    getLast = b_liq_B.pop()
                    getLast.bx.delete()
                    getLast.ln.delete()               
    //
    if pl
        dir := aZZ.d.get (0) 
        x1  := aZZ.x.get (0) 
        y1  := aZZ.y.get (0) 
        y2  :=      nz(lo[1])
        //
        if dir > -1  // if previous point was a ph, add, and change direction (-1)
            aZZ.in_out(-1, x1, y1, x2, y2, col, true)
        else
            if dir == -1 and pl < y1 
                aZZ.x.set(0, x2), aZZ.y.set(0, y2)
        //
        //Liquidity
        if showLq and per and sz > 0
            count = 0
            st_P  = 0.
            st_B  = 0
            minP  = 0.
            maxP  = 10e6
            for i = 0 to math.min(sz, 50) -1
                if aZZ.d.get(i) == -1 
                    if aZZ.y.get(i) < pl - (atr/a)
                        break
                    else
                        if aZZ.y.get(i) > pl - (atr/a) and aZZ.y.get(i) < pl + (atr/a)
                            count += 1
                            st_B := aZZ.x.get(i)
                            st_P := aZZ.y.get(i)
                            if aZZ.y.get(i) > minP
                                minP := aZZ.y.get(i)
                            if aZZ.y.get(i) < maxP 
                                maxP := aZZ.y.get(i)
            if count > 2
                getB = b_liq_S.get(0)
                if st_B == getB.bx.get_left()
                    getB.bx.set_top(math.avg(minP, maxP) + (atr/a))
                    getB.bx.set_rightbottom(n +10, math.avg(minP, maxP) - (atr/a))
                else
                    b_liq_S.unshift(liq.new(
                      box.new(
                       st_B, math.avg(minP, maxP) + (atr/a), n +10, math.avg(minP, maxP) - (atr/a)
                     , text = 'Sellside liquidity', text_size = size.tiny, text_halign = text.align_left
                     , text_valign = text.align_bottom, text_color = color.new(cLIQ_S, 25)
                     , bgcolor=color(na), border_color=color(na)
                      )
                     , false
                     , false
                     , false
                     , line.new(st_B, st_P, n -1, st_P, color = color.new(cLIQ_S, 0))
                      )
                     )  
                if b_liq_S.size() > visLiq
                    getLast = b_liq_S.pop()
                    getLast.bx.delete()
                    getLast.ln.delete()            
    //
    //Market Structure Shift 
    if showMS 
        //
        iH = aZZ.d.get(2) ==  1 ? 2 : 1
        iL = aZZ.d.get(2) == -1 ? 2 : 1
        //
        switch
            // MSS Bullish
            close > aZZ.y.get(iH) and aZZ.d.get(iH) ==  1 and MSS.dir <  1 =>
                MSS.dir :=  1 
                if i_mode == 'Present'
                    MSS.l_bosBl.clear_aLabLin(), MSS.l_bosBr.clear_aLabLin()   
                    MSS.lbBosBl.clear_aLabLin(), MSS.lbBosBr.clear_aLabLin()  
                    MSS.l_mssBl.clear_aLabLin(), MSS.l_mssBr.clear_aLabLin() 
                    MSS.lbMssBl.clear_aLabLin(), MSS.lbMssBr.clear_aLabLin() 
                //      
                MSS.l_mssBl.unshift(line.new (
                  aZZ.x.get(iH), aZZ.y.get(iH), n, aZZ.y.get(iH), color=cMSSbl))
                MSS.lbMssBl.unshift(label.new(
                  math.round(math.avg(aZZ.x.get(iH), n)), aZZ.y.get(iH), text ='MSS'
                  , style=label.style_label_down, size=size.tiny, color=color(na), textcolor=cMSSbl))
            // MSS Bearish
            close < aZZ.y.get(iL) and aZZ.d.get(iL) == -1 and MSS.dir > -1 =>
                MSS.dir := -1 
                if i_mode == 'Present'
                    MSS.l_bosBl.clear_aLabLin(), MSS.l_bosBr.clear_aLabLin()   
                    MSS.lbBosBl.clear_aLabLin(), MSS.lbBosBr.clear_aLabLin()  
                    MSS.l_mssBl.clear_aLabLin(), MSS.l_mssBr.clear_aLabLin() 
                    MSS.lbMssBl.clear_aLabLin(), MSS.lbMssBr.clear_aLabLin()
                // 
                MSS.l_mssBr.unshift(line.new (
                  aZZ.x.get(iL), aZZ.y.get(iL), n, aZZ.y.get(iL), color=cMSSbr))
                MSS.lbMssBr.unshift(label.new(
                  math.round(math.avg(aZZ.x.get(iL), n)), aZZ.y.get(iL), text ='MSS'
                  , style=label.style_label_up  , size=size.tiny, color=color(na), textcolor=cMSSbr))
            // BOS Bullish
            MSS.dir ==  1 and close > aZZ.y.get(iH) and iBOS =>
                if MSS.l_bosBl.size() > 0
                    if aZZ.y.get(iH) != MSS.l_bosBl.get(0).get_y2() and
                       aZZ.y.get(iH) != MSS.l_mssBl.get(0).get_y2()
                        MSS.l_bosBl.unshift(set_lin(iH, 'Bl')), MSS.lbBosBl.unshift(set_lab(iH, 'Bl'))
                else  
                    if aZZ.y.get(iH) != MSS.l_mssBl.get(0).get_y2()                     
                        MSS.l_bosBl.unshift(set_lin(iH, 'Bl')), MSS.lbBosBl.unshift(set_lab(iH, 'Bl'))
            // BOS Bearish
            MSS.dir == -1 and close < aZZ.y.get(iL) and iBOS =>
                if MSS.l_bosBr.size() > 0
                    if aZZ.y.get(iL) != MSS.l_bosBr.get(0).get_y2() and
                       aZZ.y.get(iL) != MSS.l_mssBr.get(0).get_y2()
                        MSS.l_bosBr.unshift(set_lin(iL, 'Br')), MSS.lbBosBr.unshift(set_lab(iL, 'Br'))
                else
                    if aZZ.y.get(iL) != MSS.l_mssBr.get(0).get_y2()                     
                        MSS.l_bosBr.unshift(set_lin(iL, 'Br')), MSS.lbBosBr.unshift(set_lab(iL, 'Br'))
        if not iMSS
            MSS.l_mssBl.get(0).set_color(color(na)), MSS.lbMssBl.get(0).set_textcolor(color(na))
            MSS.l_mssBr.get(0).set_color(color(na)), MSS.lbMssBr.get(0).set_textcolor(color(na))



//-----------------------------------------------------------------------------}
//Calculations
//-----------------------------------------------------------------------------{
draw(len, color.yellow)             

if MSS.l_bosBl.size() > 200
    MSS.l_bosBl.pop().delete()
    MSS.lbBosBl.pop().delete()

if MSS.l_bosBr.size() > 200
    MSS.l_bosBr.pop().delete()
    MSS.lbBosBr.pop().delete()

//Killzones 
ny          = time(timeframe.period, input.session('0700-0900', '', inline = 'ny', group = 'Killzones'), 'America/New_York') and showNy 
ldn_open    = time(timeframe.period, input.session('0700-1000', '', inline = 'lo', group = 'Killzones'), 'Europe/London'   ) and showLdno // 0200-0500 UTC-5
ldn_close   = time(timeframe.period, input.session('1500-1700', '', inline = 'lc', group = 'Killzones'), 'Europe/London'   ) and showLdnc // 1000-1200 UTC-5
asian       = time(timeframe.period, input.session('1000-1400', '', inline = 'as', group = 'Killzones'), 'Asia/Tokyo'      ) and showAsia // 2000-0000 UTC-5

//Pivotpoints 
ph          = ta.pivothigh(3, 1), lPh = fixnan(ph)
pl          = ta.pivotlow (3, 1), lPl = fixnan(pl)

//Candles 
L_body      = 
 high - mx  < body * perc_Body and 
 mn - low   < body * perc_Body

L_bodyUP    =   body > meanBody  and L_body and close > open
L_bodyDN    =   body > meanBody  and L_body and close < open

bsNOTbodyUP = ta.barssince(not L_bodyUP)
bsNOTbodyDN = ta.barssince(not L_bodyDN)

bsIs_bodyUP = ta.barssince(    L_bodyUP)
bsIs_bodyDN = ta.barssince(    L_bodyDN)

lwst        = math.min(lPh [bsNOTbodyUP[1]], low[bsNOTbodyUP[1]])
hgst        = math.max(high[bsNOTbodyDN[1]], lPl[bsNOTbodyDN[1]])

//Imbalance
imbalanceUP = L_bodyUP[1] and (i_FVG == 'FVG' ? low  > high[2] : low  < high[2])
imbalanceDN = L_bodyDN[1] and (i_FVG == 'FVG' ? high < low [2] : high > low [2])

//Volume Imbalance
vImb_Bl     = open > close[1] and high[1] > low  and close > close[1] and open > open[1] and high[1] < mn
vImb_Br     = open < close[1] and low [1] < high and close < close[1] and open < open[1] and low [1] > mx

if sVimbl
    if vImb_Bl
        Vimbal.unshift(
         _2ln_lb.new(
          line.new (n -1, mx[1], n +3, mx[1], color=cVimbl)
         , line.new (n   , mn   , n +3, mn   , color=cVimbl)
          , label.new(n +3, math.avg    (mx[1], mn), text='VI'
         , color=color(na) , textcolor=cVimbl, style=label.style_label_left)
          )
         )
    if vImb_Br
        Vimbal.unshift(
         _2ln_lb.new(
          line.new (n -1, mn[1], n +3, mn[1], color=cVimbl)
         , line.new (n   , mx   , n +3, mx   , color=cVimbl)
          , label.new(n +3, math.avg    (mn[1], mx), text='VI'
         , color=color(na) , textcolor=cVimbl, style=label.style_label_left)
          )
         )
    if Vimbal.size() > visVim 
        pop = Vimbal.pop()
        pop.l1.delete()
        pop.l2.delete()
        pop.lb.delete()

//Fair Value Gap  
if barstate.isfirst
    for i = 0 to visBxs -1
        bFVG_UP.unshift(FVG.new(box(na), false))
        bFVG_DN.unshift(FVG.new(box(na), false))
        if i_BPR
            bBPR_UP.unshift(FVG.new(box(na), false))
            bBPR_DN.unshift(FVG.new(box(na), false))

if imbalanceUP and per and shwFVG 
    if imbalanceUP[1]
        bFVG_UP.get(0).box.set_lefttop    (n -2, low    )
        bFVG_UP.get(0).box.set_rightbottom(n +8, high[2])
    else
        bFVG_UP.unshift(FVG.new(
          box.new(
           n -2
         ,    i_FVG == 'FVG' ? low : high[2]
         , n, i_FVG == 'FVG' ? high[2] : low
         , bgcolor     = i_BPR ? color(na) : color.new(cFVGbl, 90)
         , border_color= i_BPR ? color(na) : color.new(cFVGbl, 65)
         , text_color  = i_BPR ? color(na) : color.new(cFVGbl, 65)
         , text_size=size.small
         , text=i_FVG
         )
         , true)
         )
        bFVG_UP.pop().box.delete()

if imbalanceDN and per and shwFVG 
    if imbalanceDN[1]
        bFVG_DN.get(0).box.set_lefttop    (n -2, low[2])
        bFVG_DN.get(0).box.set_rightbottom(n +8, high  )
    else
        bFVG_DN.unshift(FVG.new(
         box.new(
           n -2
         ,    i_FVG == 'FVG' ? low[2] : high
         , n, i_FVG == 'FVG' ? high   : low[2]
         , bgcolor     = i_BPR ? color(na) : color.new(cFVGbr, 90)
         , border_color= i_BPR ? color(na) : color.new(cFVGbr, 65)
         , text_color  = i_BPR ? color(na) : color.new(cFVGbr, 65)
         , text_size=size.small
         , text=i_FVG
         )
         , true)
         )
        bFVG_DN.pop().box.delete()

//Balance Price Range (overlap of 2 latest FVG bull/bear)
if i_BPR and bFVG_UP.size() > 0 and bFVG_DN.size() > 0
    bxUP    = bFVG_UP.get(0)
    bxDN    = bFVG_DN.get(0)
    bxUPbtm = bxUP.box.get_bottom()
    bxDNbtm = bxDN.box.get_bottom()
    bxUPtop = bxUP.box.get_top()
    bxDNtop = bxDN.box.get_top()
    left    = math.min(bxUP.box.get_left (), bxDN.box.get_left ())
    right   = math.max(bxUP.box.get_right(), bxDN.box.get_right())
    //
    if bxUPbtm < bxDNtop and 
       bxDNbtm < bxUPbtm
        if left == bBPR_UP.get(0).box.get_left() 
            if  bBPR_UP.get(0).active
                bBPR_UP.get(0).box.set_right(right)
        else
            bBPR_UP.unshift(FVG.new(
             box.new(
              left, bxDNtop, right, bxUPbtm
              , bgcolor     = i_BPR ? color.new(cFVGbl, 90) : color(na)
              , border_color= i_BPR ? color.new(cFVGbl, 65) : color(na)
              , text_color  = i_BPR ? color.new(cFVGbl, 65) : color(na)
              , text_size=size.small
              , text= 'BPR'
              ) 
              , true
              , close > bxUPbtm ? 1 : close < bxDNtop ? -1 : 0
              )
             )
            bBPR_UP.pop().box.delete()
    //
    if bxDNbtm < bxUPtop and 
       bxUPbtm < bxDNbtm 
        if left == bBPR_DN.get(0).box.get_left() 
            if  bBPR_DN.get(0).active
                bBPR_DN.get(0).box.set_right(right)
        else
            bBPR_DN.unshift(FVG.new(
             box.new(
              left, bxUPtop, right, bxDNbtm
              , bgcolor     = i_BPR ? color.new(cFVGbr, 90) : color(na)
              , border_color= i_BPR ? color.new(cFVGbr, 65) : color(na)
              , text_color  = i_BPR ? color.new(cFVGbr, 65) : color(na)
              , text_size=size.small
              , text= 'BPR'
              ) 
              , true
              , close > bxDNbtm ? 1 : close < bxUPtop ? -1 : 0
              )
             )
            bBPR_DN.pop().box.delete()

//FVG's breaks
for i = 0 to math.min(bxBack, bFVG_UP.size() -1)
    getUPi = bFVG_UP.get(i)
    if getUPi.active
        getUPi.box.set_right(bar_index +8)
        if low  < getUPi.box.get_top() and not i_BPR
            getUPi.box.set_border_style(line.style_dashed)
        if low  < getUPi.box.get_bottom()
            if not i_BPR
                getUPi.box.set_bgcolor(color.new(cFVGblBR, 95))
                getUPi.box.set_border_style(line.style_dotted)
            getUPi.box.set_right(bar_index)
            getUPi.active := false

for i = 0 to math.min(bxBack, bFVG_DN.size() -1)
    getDNi = bFVG_DN.get(i)
    if getDNi.active
        getDNi.box.set_right(bar_index +8)
        if high > getDNi.box.get_bottom() and not i_BPR
            getDNi.box.set_border_style(line.style_dashed)
        if high > getDNi.box.get_top()
            if not i_BPR
                getDNi.box.set_bgcolor(color.new(cFVGbrBR, 95))
                getDNi.box.set_border_style(line.style_dotted)
            getDNi.box.set_right(bar_index)
            getDNi.active := false

if i_BPR
    for i = 0 to math.min(bxBack, bBPR_UP.size() -1)
        getUPi = bBPR_UP.get(i)
        if getUPi.active
            getUPi.box.set_right(bar_index +8)
            switch getUPi.pos 
                -1 =>
                    if high > getUPi.box.get_bottom()
                        getUPi.box.set_border_style(line.style_dashed)
                    if high > getUPi.box.get_top   ()
                        getUPi.box.set_bgcolor(color.new(cFVGblBR, 95))
                        getUPi.box.set_border_style(line.style_dotted)
                        getUPi.box.set_right(bar_index)
                        getUPi.active := false
                1 =>
                    if low  < getUPi.box.get_top   ()
                        getUPi.box.set_border_style(line.style_dashed)
                    if low  < getUPi.box.get_bottom()
                        getUPi.box.set_bgcolor(color.new(cFVGblBR, 95))
                        getUPi.box.set_border_style(line.style_dotted)
                        getUPi.box.set_right(bar_index)
                        getUPi.active := false
    
    for i = 0 to math.min(bxBack, bBPR_DN.size() -1)
        getDNi = bBPR_DN.get(i)
        if getDNi.active
            getDNi.box.set_right(bar_index +8)
            switch getDNi.pos 
                -1 =>
                    if high > getDNi.box.get_bottom()
                        getDNi.box.set_border_style(line.style_dashed)
                    if high > getDNi.box.get_top   ()
                        getDNi.box.set_bgcolor(color.new(cFVGbrBR, 95))
                        getDNi.box.set_border_style(line.style_dotted)
                        getDNi.box.set_right(bar_index)
                        getDNi.active := false
                1 =>
                    if low  < getDNi.box.get_top   ()
                        getDNi.box.set_border_style(line.style_dashed)
                    if low  < getDNi.box.get_bottom()
                        getDNi.box.set_bgcolor(color.new(cFVGbrBR, 95))
                        getDNi.box.set_border_style(line.style_dotted)
                        getDNi.box.set_right(bar_index)
                        getDNi.active := false

//NWOG/NDOG 
if barstate.isfirst 
    for i = 0 to maxNWOG -1
        bl_NWOG.unshift(bx_ln.new(box(na), line(na)))
    for i = 0 to maxNDOG -1
        bl_NDOG.unshift(bx_ln.new(box(na), line(na)))

if dayofweek == dayofweek.friday
    friCp := close, friCi := n

if ta.change(dayofweek) 
    if  dayofweek == dayofweek.monday and iNWOG
        monOp := open , monOi := n
        bl_NWOG.unshift(bx_ln.new(   
         box.new(
           friCi        ,   math.max (friCp  , monOp  )
         , monOi        ,   math.min (friCp  , monOp  )
         , bgcolor      =   color    ( na             )
         , border_color =             cNWOG2
         , extend       =             extend.right    )
         ,
         line.new(
           monOi        ,   math.avg (friCp  , monOp  ) 
         , monOi +1     ,   math.avg (friCp  , monOp  )
         , color        =             cNWOG1
         , style        =             line.style_dotted
         , extend       =             extend.right    )         
         ))
        bl = bl_NWOG.pop(), bl.b.delete(), bl.l.delete()
    if iNDOG
        cuDOp := open    , cuDOi := n
        prDCp := close[1], prDCi := n -1
        //
        bl_NDOG.unshift(bx_ln.new(   
         box.new(
           prDCi        ,   math.max (prDCp  , cuDOp  )
         , cuDOi        ,   math.min (prDCp  , cuDOp  )
         , bgcolor      =   color    ( na             )
         , border_color =             cNDOG2
         , extend       =             extend.right    )
         ,
         line.new(
           cuDOi        ,   math.avg (prDCp  , cuDOp  ) 
         , cuDOi +1     ,   math.avg (prDCp  , cuDOp  )
         , color        =             cNDOG1
         , style        =             line.style_dotted
         , extend       =             extend.right    )     
         ))
        bl = bl_NDOG.pop(), bl.b.delete(), bl.l.delete()

//Liquidity 
for i = 0 to b_liq_B.size() -1
    x = b_liq_B.get(i)
    if not x.broken
        x.bx.set_right(n +3)
        x.ln.set_x2   (n +3)
        if not x.brokenTop
            if close > x.bx.get_top   ()
                x.brokenTop := true
        if not x.brokenBtm
            if close > x.bx.get_bottom()
                x.brokenBtm := true             
        if x.brokenBtm 
            x.bx.set_bgcolor(color.new(cLIQ_B, 90))
            x.ln.delete()
            if x.brokenTop 
                x.broken := true
                x.bx.set_right(n)

for i = 0 to b_liq_S.size() -1
    x = b_liq_S.get(i)
    if not x.broken
        x.bx.set_right(n +3)
        x.ln.set_x2   (n +3)
        if not x.brokenTop
            if close < x.bx.get_top   ()
                x.brokenTop := true
        if not x.brokenBtm
            if close < x.bx.get_bottom()
                x.brokenBtm := true             
        if x.brokenTop 
            x.bx.set_bgcolor(color.new(cLIQ_S, 90))
            x.ln.delete()
            if x.brokenBtm
                x.broken := true
                x.bx.set_right(n)

//Order Blocks   
[top, btm] = swings(length)

if showOB and per
    if close > top.y and not top.crossed 
        top.crossed := true
        
        minima = max[1]
        maxima = min[1]
        loc = time[1]
        
        for i = 1 to (n - top.x)-1
            minima := math.min(min[i], minima)
            maxima := minima == min[i] ? max[i] : maxima
            loc := minima == min[i] ? time[i] : loc
        bullish_ob.unshift(ob.new(maxima, minima, loc))
    
    if bullish_ob.size() > 0 
        for i = bullish_ob.size()-1 to 0
            element = bullish_ob.get(i)
            
            if not element.breaker 
                if math.min(close, open) < element.btm
                    element.breaker := true
                    element.break_loc := time
            else
                if close > element.top
                    bullish_ob.remove(i)
                else if i < showBull and top.y < element.top and top.y > element.btm 
                    blBrkConf := 1

    //Set label
    if blBrkConf > blBrkConf[1] and showLabels
        label.new(top.x, top.y, '▼', color = na
          , textcolor = bearCss.notransp()
          , style = label.style_label_down
          , size = size.tiny)

if showOB and per
    if close < btm.y and not btm.crossed 
        btm.crossed := true

        minima = min[1]
        maxima = max[1]
        loc = time[1]

        for i = 1 to (n - btm.x)-1
            maxima := math.max(max[i], maxima)
            minima := maxima == max[i] ? min[i] : minima
            loc := maxima == max[i] ? time[i] : loc
        bearish_ob.unshift(ob.new(maxima, minima, loc))

    if bearish_ob.size() > 0 
        for i = bearish_ob.size()-1 to 0
            element = bearish_ob.get(i)

            if not element.breaker 
                if math.max(close, open) > element.top
                    element.breaker := true
                    element.break_loc := time
            else
                if close < element.btm
                    bearish_ob.remove(i)
                else if i < showBear and btm.y > element.btm and btm.y < element.top 
                    brBrkConf := 1

    //Set label
    if brBrkConf > brBrkConf[1] and showLabels 
        label.new(btm.x, btm.y, '▲', color = na
          , textcolor = bullCss.notransp()
          , style = label.style_label_up
          , size = size.tiny)

//-----------------------------------------------------------------------------}
//Set Order Blocks
//-----------------------------------------------------------------------------{
if barstate.islast and showOB 
    if a_bx_ln_lb.size() > 0
        for i = a_bx_ln_lb.size() -1 to 0 
            item = a_bx_ln_lb.remove(i)
            item.bx.delete()
            item.ln.delete()
            item.lb.delete()
    //Bullish
    if showBull > 0
        blSz = bullish_ob.size()
        if blSz > 0
            for i = 0 to math.min(showBull, bullish_ob.size()) -1
                get_ob = bullish_ob.get(i)
                get_ob.display(bullCss, bullBrkCss, 'bl')
    //Bearish
    if showBear > 0
        brSz = bearish_ob.size()
        if brSz > 0
            for i = 0 to math.min(showBear, bearish_ob.size()) -1
                get_ob = bearish_ob.get(i)
                get_ob.display(bearCss, bearBrkCss, 'br')

//-----------------------------------------------------------------------------}
//Fibonacci
//-----------------------------------------------------------------------------{
if barstate.islast
    x1 = 0, y1 = 0., x2 = 0, y2 = 0., box up = na, box dn = na
    switch iFib
        'FVG'   =>
            if bFVG_UP.size() > 0 and bFVG_DN.size() > 0
                up  := bFVG_UP.get(0).box
                dn  := bFVG_DN.get(0).box
                dnFirst = up.get_left() > dn.get_left()
                dnBottm = up.get_top () > dn.get_top ()
                x1  := dnFirst ? dn.get_left  () : up.get_left  ()
                x2  := dnFirst ? up.get_right () : dn.get_right ()
                y1  := dnFirst ? 
                 dnBottm       ? dn.get_bottom() : dn.get_top   () :
                 dnBottm       ? up.get_top   () : up.get_bottom()
                y2  := dnFirst ? 
                 dnBottm       ? up.get_top   () : up.get_bottom() :
                 dnBottm       ? dn.get_bottom() : dn.get_top   ()
        'BPR'   =>
            if bBPR_UP.size() > 0 and bBPR_DN.size() > 0
                up  := bBPR_UP.get(0).box
                dn  := bBPR_DN.get(0).box
                dnFirst = up.get_left() > dn.get_left()
                dnBottm = up.get_top () > dn.get_top ()
                x1  := dnFirst ? dn.get_left  () : up.get_left  ()
                x2  := dnFirst ? up.get_right () : dn.get_right ()
                y1  := dnFirst ? 
                 dnBottm       ? dn.get_bottom() : dn.get_top   () :
                 dnBottm       ? up.get_top   () : up.get_bottom()
                y2  := dnFirst ? 
                 dnBottm       ? up.get_top   () : up.get_bottom() :
                 dnBottm       ? dn.get_bottom() : dn.get_top   ()
        'OB'    =>
            oSz = a_bx_ln_lb.size()
            if oSz > 1
                xA = nz(
                   a_bx_ln_lb.get(oSz -1).ln.get_x1    () 
                 , a_bx_ln_lb.get(oSz -1).bx.get_left  ()
                 )
                xB = nz(
                   a_bx_ln_lb.get(oSz -2).ln.get_x1    () 
                 , a_bx_ln_lb.get(oSz -2).bx.get_left  ()
                 ) 
                AFirst = xB > xA
                //
                yAT = nz(
                   a_bx_ln_lb.get(oSz -1).ln.get_y1    () 
                 , a_bx_ln_lb.get(oSz -1).bx.get_top   ()
                 )
                yAB = nz(
                   a_bx_ln_lb.get(oSz -1).ln.get_y1    () 
                 , a_bx_ln_lb.get(oSz -1).bx.get_bottom()
                 )          
                yBT = nz(
                   a_bx_ln_lb.get(oSz -2).ln.get_y1    () 
                 , a_bx_ln_lb.get(oSz -2).bx.get_top   ()
                 )
                yBB = nz(
                   a_bx_ln_lb.get(oSz -2).ln.get_y1    () 
                 , a_bx_ln_lb.get(oSz -2).bx.get_bottom()
                 ) 
                ABottom = yAB < yBB
                //
                x1  := AFirst ? xA : xB
                x2  := AFirst ? xB : xA
                y1  := AFirst ? 
                 ABottom ? yAB : yAT :
                 ABottom ? yBT : yBB
                y2  := AFirst ? 
                 ABottom ? yBT : yBB :
                 ABottom ? yAB : yAT
        'Liq'   =>
            if b_liq_B.size() > 0 and b_liq_S.size() > 0
                xA = nz(
                   b_liq_B.get(0).ln.get_x1    () 
                 , b_liq_B.get(0).bx.get_left  ()
                 )
                xB = nz(
                   b_liq_S.get(0).ln.get_x1    () 
                 , b_liq_S.get(0).bx.get_left  ()
                 ) 
                AFirst = xB > xA
                //
                yAT = nz(
                   b_liq_B.get(0).ln.get_y1    () 
                 , b_liq_B.get(0).bx.get_top   ()
                 )
                yAB = nz(
                   b_liq_B.get(0).ln.get_y1    () 
                 , b_liq_B.get(0).bx.get_bottom()
                 )          
                yBT = nz(
                   b_liq_S.get(0).ln.get_y1    () 
                 , b_liq_S.get(0).bx.get_top   ()
                 )
                yBB = nz(
                   b_liq_S.get(0).ln.get_y1    () 
                 , b_liq_S.get(0).bx.get_bottom()
                 ) 
                ABottom = yAB < yBB
                //
                x1  := AFirst ? xA : xB
                x2  := AFirst ? xB : xA
                y1  := AFirst ? 
                 ABottom ? yAB : yAT :
                 ABottom ? yBT : yBB
                y2  := AFirst ? 
                 ABottom ? yBT : yBB :
                 ABottom ? yAB : yAT
        'VI'    =>
            if Vimbal.size() > 1
                AxA = Vimbal.get(1).l2.get_x1(), AxB = Vimbal.get(1).l1.get_x1()
                BxA = Vimbal.get(0).l2.get_x1(), BxB = Vimbal.get(0).l1.get_x1()
                AyA = Vimbal.get(1).l2.get_y1(), AyB = Vimbal.get(1).l1.get_y1()
                ByA = Vimbal.get(0).l2.get_y1(), ByB = Vimbal.get(0).l1.get_y1()
                ABt = math.min(ByA, ByB) > math.min(AyA, AyB) 
                x1 := math.max(AxA, AxB) 
                x2 := math.max(BxA, BxB) 
                y1 := ABt ? math.min(AyA, AyB) : math.max(AyA, AyB) 
                y2 := ABt ? math.max(ByA, ByB) : math.min(ByA, ByB)  
        'NWOG'  =>
            if bl_NWOG.size() > 1
                up  := bl_NWOG.get(0).b
                dn  := bl_NWOG.get(1).b
                dnFirst = up.get_left() > dn.get_left()
                dnBottm = up.get_top () > dn.get_top ()
                x1  := dnFirst ? dn.get_left () : up.get_left ()
                x2  := dnFirst ? up.get_right() : dn.get_right()
                y1  := dnFirst ? 
                 dnBottm ? dn.get_bottom() : dn.get_top   () :
                 dnBottm ? up.get_top   () : up.get_bottom()
                y2  := dnFirst ? 
                 dnBottm ? up.get_top   () : up.get_bottom() :
                 dnBottm ? dn.get_bottom() : dn.get_top   ()
    //
    if iFib != 'NONE'
        rt = math.max(x1, x2)
        lt = math.min(x1, x2)
        tp = math.max(y1, y2)
        bt = math.min(y1, y2)
        _0 = rt == x1 ? y1 : y2
        _1 = rt == x1 ? y2 : y1
        //
        df = _1 - _0
        m0236 = df * 0.236 
        m0382 = df * 0.382 
        m0500 = df * 0.500 
        m0618 = df * 0.618 
        m0786 = df * 0.786 
        m1618 = df * 1.618 
        //
        _diag.setLine(x1, y1        , x2       , y2        )
        _vert.setLine(rt, _0        , rt       , _0 + m1618)
        _zero.setLine(rt, _0        , rt + plus, _0        )
        _0236.setLine(rt, _0 + m0236, rt + plus, _0 + m0236)
        _0382.setLine(rt, _0 + m0382, rt + plus, _0 + m0382)
        _0500.setLine(rt, _0 + m0500, rt + plus, _0 + m0500)
        _0618.setLine(rt, _0 + m0618, rt + plus, _0 + m0618)
        _0786.setLine(rt, _0 + m0786, rt + plus, _0 + m0786)
        _one_.setLine(rt, _1        , rt + plus, _1        )
        _1618.setLine(rt, _0 + m1618, rt + plus, _0 + m1618)

//-----------------------------------------------------------------------------}
//Displacement
//-----------------------------------------------------------------------------{
plotshape(sDispl ? per       ? 
     L_bodyUP    ? low  : na : na : na
     , title     = 'Displacement UP'
     , style     = shape.labelup  
     , color     = color.lime
     , location  = location.belowbar)
plotshape(sDispl ? per       ?
     L_bodyDN    ? high : na : na : na
     , title     = 'Displacement DN'
     , style     = shape.labeldown
     , color     = color.red 
     , location  = location.abovebar)

//-----------------------------------------------------------------------------}
//background - Killzones
//-----------------------------------------------------------------------------{
bgcolor  (per    ? ny        ? nyCss   : na : na, editable = false)
bgcolor  (per    ? ldn_open  ? ldnoCss : na : na, editable = false)
bgcolor  (per    ? ldn_close ? ldncCss : na : na, editable = false)
bgcolor  (per    ? asian     ? asiaCss : na : na, editable = false)

//-----------------------------------------------------------------------------}

//==================== AMY PIVOT V2 ====================//
amyPivotV2_group = "AMY Pivot V2"
amyPivotV2_show = input.bool(true, "Show Pivot Levels", group=amyPivotV2_group)
amyPivotV2_tf = input.string("D", "Pivot Source TF", options=["D", "W", "M"], group=amyPivotV2_group)
amyPivotV2_displayMode = input.string("Clean", "Pivot Display Mode", options=["All", "Clean", "Major Only"], group=amyPivotV2_group)
amyPivotV2_showLabels = input.bool(true, "Show Pivot Price Labels", group=amyPivotV2_group)
amyPivotV2_backBars = input.int(80, "Left Bars", minval=10, maxval=500, group=amyPivotV2_group)
amyPivotV2_extendBars = input.int(40, "Right Bars", minval=5, maxval=300, group=amyPivotV2_group)
amyPivotV2_lineWidth = input.int(1, "Line Width", minval=1, maxval=4, group=amyPivotV2_group)
amyPivotV2_nearAtrMult = input.float(2.0, "Show Level If Near ATR", minval=0.5, step=0.5, group=amyPivotV2_group)

amyPivotV2_rawHigh = request.security(syminfo.tickerid, amyPivotV2_tf, high, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
amyPivotV2_rawLow = request.security(syminfo.tickerid, amyPivotV2_tf, low, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
amyPivotV2_rawClose = request.security(syminfo.tickerid, amyPivotV2_tf, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

amyPivotV2_newTfBar = ta.change(time(amyPivotV2_tf)) != 0

var float amyPivotV2_prevHigh = na
var float amyPivotV2_prevLow = na
var float amyPivotV2_prevClose = na

if amyPivotV2_newTfBar or na(amyPivotV2_prevHigh)
    amyPivotV2_prevHigh := amyPivotV2_rawHigh[1]
    amyPivotV2_prevLow := amyPivotV2_rawLow[1]
    amyPivotV2_prevClose := amyPivotV2_rawClose[1]

amyPivotV2_atr = ta.atr(14)
amyPivotV2_range = amyPivotV2_prevHigh - amyPivotV2_prevLow
amyPivotV2_p = (amyPivotV2_prevHigh + amyPivotV2_prevLow + amyPivotV2_prevClose) / 3.0

amyPivotV2_r1 = 2.0 * amyPivotV2_p - amyPivotV2_prevLow
amyPivotV2_s1 = 2.0 * amyPivotV2_p - amyPivotV2_prevHigh
amyPivotV2_r2 = amyPivotV2_p + amyPivotV2_range
amyPivotV2_s2 = amyPivotV2_p - amyPivotV2_range
amyPivotV2_r3 = amyPivotV2_prevHigh + 2.0 * (amyPivotV2_p - amyPivotV2_prevLow)
amyPivotV2_s3 = amyPivotV2_prevLow - 2.0 * (amyPivotV2_prevHigh - amyPivotV2_p)
amyPivotV2_r4 = amyPivotV2_r3 + amyPivotV2_range
amyPivotV2_s4 = amyPivotV2_s3 - amyPivotV2_range

amyPivotV2_isNear(_lvl) =>
    not na(_lvl) and math.abs(close - _lvl) <= amyPivotV2_atr * amyPivotV2_nearAtrMult

amyPivotV2_showLevel(_lvl, _name) =>
    amyPivotV2_displayMode == "All" ? true :
     amyPivotV2_displayMode == "Major Only" ? (_name == "PIVOT" or _name == "R1" or _name == "S1") :
     _name == "PIVOT" or _name == "R1" or _name == "S1" or amyPivotV2_isNear(_lvl)

var line[] amyPivotV2_lines = array.new<line>(9, na)
var label[] amyPivotV2_labels = array.new<label>(9, na)
var string amyPivotV2_lastTf = ""

if amyPivotV2_lastTf != amyPivotV2_tf
    for i = 0 to array.size(amyPivotV2_lines) - 1
        amyPivotV2_oldLine = array.get(amyPivotV2_lines, i)
        amyPivotV2_oldLabel = array.get(amyPivotV2_labels, i)
        if not na(amyPivotV2_oldLine)
            line.delete(amyPivotV2_oldLine)
            array.set(amyPivotV2_lines, i, na)
        if not na(amyPivotV2_oldLabel)
            label.delete(amyPivotV2_oldLabel)
            array.set(amyPivotV2_labels, i, na)
    amyPivotV2_lastTf := amyPivotV2_tf

amyPivotV2_draw(_idx, _price, _name, _baseColor) =>
    line _ln = array.get(amyPivotV2_lines, _idx)
    label _lb = array.get(amyPivotV2_labels, _idx)
    _show = amyPivotV2_show and not na(_price) and amyPivotV2_showLevel(_price, _name)
    _txt = _name + "  " + str.tostring(_price, format.mintick)
    _left = math.max(0, bar_index - amyPivotV2_backBars)
    _right = bar_index + amyPivotV2_extendBars

    if _show
        if na(_ln)
            _ln := line.new(_left, _price, _right, _price, xloc=xloc.bar_index, extend=extend.none, color=_baseColor, width=amyPivotV2_lineWidth)
        else
            line.set_xy1(_ln, _left, _price)
            line.set_xy2(_ln, _right, _price)
            line.set_color(_ln, _baseColor)
            line.set_width(_ln, amyPivotV2_lineWidth)
            line.set_style(_ln, line.style_solid)

        if amyPivotV2_showLabels
            if na(_lb)
                _lb := label.new(_right, _price, _txt, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(_baseColor, 82), textcolor=_baseColor, size=size.tiny)
            else
                label.set_xy(_lb, _right, _price)
                label.set_text(_lb, _txt)
                label.set_color(_lb, color.new(_baseColor, 82))
                label.set_textcolor(_lb, _baseColor)
                label.set_size(_lb, size.tiny)
        else
            if not na(_lb)
                label.delete(_lb)
                _lb := na
    else
        if not na(_ln)
            line.delete(_ln)
            _ln := na
        if not na(_lb)
            label.delete(_lb)
            _lb := na

    array.set(amyPivotV2_lines, _idx, _ln)
    array.set(amyPivotV2_labels, _idx, _lb)

amyPivotV2_draw(0, amyPivotV2_r4, "R4", color.new(color.red, 35))
amyPivotV2_draw(1, amyPivotV2_r3, "R3", color.new(color.red, 30))
amyPivotV2_draw(2, amyPivotV2_r2, "R2", color.new(color.red, 20))
amyPivotV2_draw(3, amyPivotV2_r1, "R1", color.new(color.red, 10))
amyPivotV2_draw(4, amyPivotV2_p, "PIVOT", color.new(color.blue, 0))
amyPivotV2_draw(5, amyPivotV2_s1, "S1", color.new(color.lime, 10))
amyPivotV2_draw(6, amyPivotV2_s2, "S2", color.new(color.lime, 20))
amyPivotV2_draw(7, amyPivotV2_s3, "S3", color.new(color.lime, 30))
amyPivotV2_draw(8, amyPivotV2_s4, "S4", color.new(color.lime, 35))

//==================== AMY KEY LEVELS V2 ====================//
amyKeyV2_group = "AMY Key Levels V2"
amyKeyV2_show = input.bool(true, "Show Key Levels", group=amyKeyV2_group)
amyKeyV2_showLabels = input.bool(true, "Show Key Level Labels", group=amyKeyV2_group)
amyKeyV2_backBars = input.int(80, "Left Bars", minval=10, maxval=500, group=amyKeyV2_group)
amyKeyV2_extendBars = input.int(40, "Right Bars", minval=5, maxval=300, group=amyKeyV2_group)
amyKeyV2_lineWidth = input.int(1, "Line Width", minval=1, maxval=4, group=amyKeyV2_group)

amyKeyV2_showMO = input.bool(true, "Show Midnight Open", group=amyKeyV2_group)
amyKeyV2_showPDH = input.bool(true, "Show PDH", group=amyKeyV2_group)
amyKeyV2_showPDL = input.bool(true, "Show PDL", group=amyKeyV2_group)
amyKeyV2_showBSL = input.bool(false, "Show BSL", group=amyKeyV2_group)
amyKeyV2_showSSL = input.bool(false, "Show SSL", group=amyKeyV2_group)
amyKeyV2_showAsiaHigh = input.bool(true, "Show Asia High", group=amyKeyV2_group)
amyKeyV2_showAsiaLow = input.bool(true, "Show Asia Low", group=amyKeyV2_group)

amyKeyV2_moTz = input.string("America/New_York", "Midnight Open Timezone", group=amyKeyV2_group)
amyKeyV2_swingLen = input.int(5, "BSL / SSL Swing Length", minval=1, maxval=50, group=amyKeyV2_group)

amyKeyV2_moEngine() =>
    var float _mo = na
    _newDay = ta.change(time("D", "0000-2359", amyKeyV2_moTz)) != 0
    if _newDay or na(_mo)
        _mo := open
    _mo

amyKeyV2_moFixed = request.security(syminfo.tickerid, "1", amyKeyV2_moEngine(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

var float amyKeyV2_moFallback = na
amyKeyV2_newDayChart = ta.change(time("D", "0000-2359", amyKeyV2_moTz)) != 0

if amyKeyV2_newDayChart or na(amyKeyV2_moFallback)
    amyKeyV2_moFallback := open

amyKeyV2_midnightOpen = na(amyKeyV2_moFixed) ? amyKeyV2_moFallback : amyKeyV2_moFixed

amyKeyV2_rawDailyHigh = request.security(syminfo.tickerid, "D", high, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
amyKeyV2_rawDailyLow = request.security(syminfo.tickerid, "D", low, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

amyKeyV2_newExchangeDay = ta.change(time("D")) != 0

var float amyKeyV2_pdh = na
var float amyKeyV2_pdl = na

if amyKeyV2_newExchangeDay or na(amyKeyV2_pdh)
    amyKeyV2_pdh := amyKeyV2_rawDailyHigh[1]
    amyKeyV2_pdl := amyKeyV2_rawDailyLow[1]

amyKeyV2_ph = ta.pivothigh(high, amyKeyV2_swingLen, amyKeyV2_swingLen)
amyKeyV2_pl = ta.pivotlow(low, amyKeyV2_swingLen, amyKeyV2_swingLen)

var float amyKeyV2_bsl = na
var float amyKeyV2_ssl = na

if not na(amyKeyV2_ph)
    amyKeyV2_bsl := amyKeyV2_ph

if not na(amyKeyV2_pl)
    amyKeyV2_ssl := amyKeyV2_pl

// === Asia Session High/Low Engine (Anti-Repaint) ===
amyKeyV2_asiaEngine() =>
    var float _asiaH = na
    var float _asiaL = na
    var float _lockedH = na
    var float _lockedL = na
    _inAsia = not na(time(timeframe.period, "2000-0000", "America/New_York"))
    _prevInAsia = not na(time(timeframe.period, "2000-0000", "America/New_York"))[1]
    // Sesi Asia mulai — reset tracking
    if _inAsia and not _prevInAsia
        _asiaH := high
        _asiaL := low
    // Selama sesi aktif — update high/low
    if _inAsia
        _asiaH := math.max(nz(_asiaH, high), high)
        _asiaL := math.min(nz(_asiaL, low), low)
    // Sesi Asia selesai — lock nilai
    if not _inAsia and _prevInAsia
        _lockedH := _asiaH
        _lockedL := _asiaL
    // Return: selama sesi = live tracking, setelah sesi = locked
    _resultH = _inAsia ? _asiaH : _lockedH
    _resultL = _inAsia ? _asiaL : _lockedL
    [_resultH, _resultL]

[amyKeyV2_asiaHighRaw, amyKeyV2_asiaLowRaw] = request.security(syminfo.tickerid, "1", amyKeyV2_asiaEngine(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// Fallback untuk timeframe tinggi
var float amyKeyV2_asiaHighFb = na
var float amyKeyV2_asiaLowFb = na
amyKeyV2_chartInAsia = not na(time(timeframe.period, "2000-0000", "America/New_York"))
amyKeyV2_chartPrevAsia = not na(time(timeframe.period, "2000-0000", "America/New_York"))[1]

if amyKeyV2_chartInAsia and not amyKeyV2_chartPrevAsia
    amyKeyV2_asiaHighFb := high
    amyKeyV2_asiaLowFb := low
if amyKeyV2_chartInAsia
    amyKeyV2_asiaHighFb := math.max(nz(amyKeyV2_asiaHighFb, high), high)
    amyKeyV2_asiaLowFb := math.min(nz(amyKeyV2_asiaLowFb, low), low)

amyKeyV2_asiaHigh = na(amyKeyV2_asiaHighRaw) ? amyKeyV2_asiaHighFb : amyKeyV2_asiaHighRaw
amyKeyV2_asiaLow = na(amyKeyV2_asiaLowRaw) ? amyKeyV2_asiaLowFb : amyKeyV2_asiaLowRaw

var line[] amyKeyV2_lines = array.new<line>(7, na)
var label[] amyKeyV2_labels = array.new<label>(7, na)

amyKeyV2_draw(_idx, _price, _name, _col, _showLevel) =>
    line _ln = array.get(amyKeyV2_lines, _idx)
    label _lb = array.get(amyKeyV2_labels, _idx)
    _show = amyKeyV2_show and _showLevel and not na(_price)
    _txt = _name + "  " + str.tostring(_price, format.mintick)
    _left = math.max(0, bar_index - amyKeyV2_backBars)
    _right = bar_index + amyKeyV2_extendBars

    if _show
        if na(_ln)
            _ln := line.new(_left, _price, _right, _price, xloc=xloc.bar_index, extend=extend.none, color=_col, width=amyKeyV2_lineWidth)
        else
            line.set_xy1(_ln, _left, _price)
            line.set_xy2(_ln, _right, _price)
            line.set_color(_ln, _col)
            line.set_width(_ln, amyKeyV2_lineWidth)
            line.set_style(_ln, line.style_solid)

        if amyKeyV2_showLabels
            if na(_lb)
                _lb := label.new(_right, _price, _txt, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(_col, 82), textcolor=_col, size=size.tiny)
            else
                label.set_xy(_lb, _right, _price)
                label.set_text(_lb, _txt)
                label.set_color(_lb, color.new(_col, 82))
                label.set_textcolor(_lb, _col)
                label.set_size(_lb, size.tiny)
        else
            if not na(_lb)
                label.delete(_lb)
                _lb := na
    else
        if not na(_ln)
            line.delete(_ln)
            _ln := na
        if not na(_lb)
            label.delete(_lb)
            _lb := na

    array.set(amyKeyV2_lines, _idx, _ln)
    array.set(amyKeyV2_labels, _idx, _lb)

amyKeyV2_draw(0, amyKeyV2_midnightOpen, "MO", color.new(color.yellow, 0), amyKeyV2_showMO)
amyKeyV2_draw(1, amyKeyV2_pdh, "PDH", color.new(color.red, 0), amyKeyV2_showPDH)
amyKeyV2_draw(2, amyKeyV2_pdl, "PDL", color.new(color.lime, 0), amyKeyV2_showPDL)
amyKeyV2_draw(3, amyKeyV2_bsl, "BSL", color.new(color.fuchsia, 0), amyKeyV2_showBSL)
amyKeyV2_draw(4, amyKeyV2_ssl, "SSL", color.new(color.aqua, 0), amyKeyV2_showSSL)
amyKeyV2_draw(5, amyKeyV2_asiaHigh, "ASIA H", color.new(#ff6d00, 0), amyKeyV2_showAsiaHigh)
amyKeyV2_draw(6, amyKeyV2_asiaLow, "ASIA L", color.new(#00b0ff, 0), amyKeyV2_showAsiaLow)

amyDashV2_group = "AMY Dashboard Bias V2"
amyDashV2_show = input.bool(true, "Show Dashboard", group=amyDashV2_group)
amyDashV2_posInput = input.string("Bottom Right", "Dashboard Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=amyDashV2_group)
amyDashV2_swingLen = input.int(3, "M15 Protected Swing Length", minval=2, maxval=10, group=amyDashV2_group)
amyDashV2_sweepFreshBars = input.int(16, "Sweep Fresh Bars", minval=3, maxval=30, group=amyDashV2_group)
amyDashV2_nearInvalidAtr = input.float(0.35, "Near Invalid ATR", minval=0.05, maxval=2.0, step=0.05, group=amyDashV2_group)
amyDashV2_dispMult = input.float(1.20, "Displacement Body Mult", minval=0.80, maxval=3.0, step=0.05, group=amyDashV2_group)
amyDashV2_minSweepTicks = input.int(1, "False Sweep Filter Ticks", minval=0, maxval=20, group=amyDashV2_group)
amyDashV2_poiMinAgeBars = input.int(1, "POI Min Age (M15 Bars)", minval=0, maxval=8, group=amyDashV2_group, tooltip="POI tetap terlihat sejak terbentuk, tetapi baru boleh memberi skor setelah bertahan sejumlah closed M15 bar ini.")

amyDashV2_pos(_pos) =>
    _pos == "Top Left" ? position.top_left :
     _pos == "Bottom Right" ? position.bottom_right :
     _pos == "Bottom Left" ? position.bottom_left :
     position.top_right

amyDashV2_price(_x) =>
    na(_x) ? "-" : str.tostring(_x, format.mintick)

amyDashV2_range(_a, _b) =>
    na(_a) or na(_b) ? "-" : amyDashV2_price(math.max(_a, _b)) + " - " + amyDashV2_price(math.min(_a, _b))

amyDashV2_dist(_price, _current) =>
    na(_price) or na(_current) ? "-" : amyDashV2_price(math.abs(_current - _price))

amyDashV2_join(_a, _b) =>
    _a == "" ? _b : _b == "" ? _a : _a + " | " + _b

amyDashV2_clip(_s, _max) =>
    str.length(_s) > _max ? str.substring(_s, 0, _max) + "..." : _s

amyDashV2_engine(_swingLen, _freshBars, _nearAtr, _dispMult, _minSweepTicks, _poiMinAgeBars) =>
    var float _lastPH = na
    var float _lastPL = na
    var int _biasDir = 0
    var int _mssDir = 0
    var float _lockedInvalid = na
    var float _rangeHigh = na
    var float _rangeLow = na

    // Sweep snapshot state
    var int _lastSweepDir = 0
    var int _lastSweepBar = na
    var float _sweptPrice = na
    var float _sweepExtreme = na

    // DOL persistent state: 0=None, 1=Active, 2=Reached, 3=Invalid, 4=Expired, 5=Abandoned.
    var int _dolState = 0
    var int _dolDirLocked = 0
    var int _dolStartBar = na
    var float _dolTargetLocked = na
    var float _sweepExtremeLocked = na

    // POI state
    var float _bullFvgTop = na
    var float _bullFvgBtm = na
    var int _bullFvgStatus = 0
    var float _bearFvgTop = na
    var float _bearFvgBtm = na
    var int _bearFvgStatus = 0
    var float _bullObTop = na
    var float _bullObBtm = na
    var int _bullObStatus = 0
    var float _bearObTop = na
    var float _bearObBtm = na
    var int _bearObStatus = 0

    // FIX PXI: creation bars enforce at least one closed M15 bar before transition.
    var int _bullFvgCreatedBar = na
    var int _bearFvgCreatedBar = na
    var int _bullObCreatedBar = na
    var int _bearObCreatedBar = na

    // Closed M15 snapshot
    _o = open[1]
    _h = high[1]
    _l = low[1]
    _c = close[1]
    _pc = close[2]
    _bi = bar_index[1]
    _atr = ta.atr(14)[1]
    _body = math.abs(close[1] - open[1])
    _meanBody = ta.sma(math.abs(close - open), 20)[1]

    // Protected swings
    _ph = ta.pivothigh(high, _swingLen, _swingLen)[1]
    _pl = ta.pivotlow(low, _swingLen, _swingLen)[1]

    if not na(_ph)
        _lastPH := _ph

    if not na(_pl)
        _lastPL := _pl

    // Market structure
    _bullMss = not na(_lastPH) and not na(_lastPL) and _c > _lastPH and _pc <= _lastPH
    _bearMss = not na(_lastPH) and not na(_lastPL) and _c < _lastPL and _pc >= _lastPL

    _invalidNow = false
    _biasChanged = false

    if _biasDir == 1 and not na(_lockedInvalid) and _c < _lockedInvalid
        _invalidNow := true
        if _bearMss
            _biasDir := -1
            _mssDir := -1
            _lockedInvalid := _lastPH
            _rangeHigh := _lastPH
            _rangeLow := math.min(_lastPL, _l)
        else
            _biasDir := 0
            _mssDir := 0
        _biasChanged := true

    else if _biasDir == -1 and not na(_lockedInvalid) and _c > _lockedInvalid
        _invalidNow := true
        if _bullMss
            _biasDir := 1
            _mssDir := 1
            _lockedInvalid := _lastPL
            _rangeHigh := math.max(_lastPH, _h)
            _rangeLow := _lastPL
        else
            _biasDir := 0
            _mssDir := 0
        _biasChanged := true

    else if _bullMss and _biasDir != 1
        _biasDir := 1
        _mssDir := 1
        _lockedInvalid := _lastPL
        _rangeHigh := math.max(_lastPH, _h)
        _rangeLow := _lastPL
        _biasChanged := true

    else if _bearMss and _biasDir != -1
        _biasDir := -1
        _mssDir := -1
        _lockedInvalid := _lastPH
        _rangeHigh := _lastPH
        _rangeLow := math.min(_lastPL, _l)
        _biasChanged := true

    else if _bullMss and _biasDir == 1
        _mssDir := 1
        _rangeHigh := na(_rangeHigh) ? math.max(_lastPH, _h) : math.max(_rangeHigh, _h)

    else if _bearMss and _biasDir == -1
        _mssDir := -1
        _rangeLow := na(_rangeLow) ? math.min(_lastPL, _l) : math.min(_rangeLow, _l)

    // Bias changes are resolved by the DOL state machine below.
    // An Active DOL becomes Abandoned(5) instead of disappearing into None(0).

    _nearInvalid = _biasDir == 1 and not na(_lockedInvalid) ? _c <= _lockedInvalid + _atr * _nearAtr :
     _biasDir == -1 and not na(_lockedInvalid) ? _c >= _lockedInvalid - _atr * _nearAtr :
     false

    _invalidStatus = _biasDir == 0 and _invalidNow ? 2 : _nearInvalid ? 1 : _biasDir != 0 ? 0 : 3

    _bsl = _lastPH
    _ssl = _lastPL
    _sweepMin = syminfo.mintick * _minSweepTicks

    // Resolve the old DOL before any new sweep can replace it.
    // Priority on the same closed candle: Reached > Invalid > Abandoned > Expired.
    bool _dolReachedNow = false
    bool _dolInvalidNow = false
    bool _dolExpiredNow = false
    bool _dolAbandonedNow = false
    bool _dolTerminalNow = false

    if _dolState == 1
        // No same-candle reach; target remains the level locked at sweep creation.
        _dolReachedNow := not na(_dolStartBar) and _bi > _dolStartBar and not na(_dolTargetLocked) and
         ((_dolDirLocked == 1 and _h >= _dolTargetLocked) or
          (_dolDirLocked == -1 and _l <= _dolTargetLocked))

        // Structural invalidation uses candle close beyond the locked sweep extreme.
        _dolInvalidNow := not na(_sweepExtremeLocked) and
         ((_dolDirLocked == 1 and _c < _sweepExtremeLocked) or
          (_dolDirLocked == -1 and _c > _sweepExtremeLocked))

        // A changed parent bias makes the old target irrelevant without calling it price failure.
        _dolAbandonedNow := _biasChanged

        // Expire exactly at the configured freshness boundary.
        _dolExpiredNow := not na(_dolStartBar) and _bi - _dolStartBar >= _freshBars

        if _dolReachedNow
            _dolState := 2
            _dolTerminalNow := true
        else if _dolInvalidNow
            _dolState := 3
            _dolTerminalNow := true
        else if _dolAbandonedNow
            _dolState := 5
            _dolTerminalNow := true
        else if _dolExpiredNow
            _dolState := 4
            _dolTerminalNow := true

    // If there is no Active DOL to abandon, a bias change clears stale terminal context.
    else if _biasChanged
        _lastSweepDir := 0
        _lastSweepBar := na
        _sweptPrice := na
        _sweepExtreme := na
        _dolState := 0
        _dolDirLocked := 0
        _dolStartBar := na
        _dolTargetLocked := na
        _sweepExtremeLocked := na

    // New sweep detection occurs only after the old DOL has been resolved.
    _bslSweepNow = not na(_bsl) and _h > _bsl and _c < _bsl and (_h - _bsl) >= _sweepMin
    _sslSweepNow = not na(_ssl) and _l < _ssl and _c > _ssl and (_ssl - _l) >= _sweepMin

    // Preserve a terminal state for at least its first snapshot; a later sweep may start a new DOL.
    _canStartNewDol = not _dolTerminalNow and _dolState != 1

    if _canStartNewDol
        if _sslSweepNow and not _bslSweepNow and not na(_bsl)
            _lastSweepDir := 1
            _lastSweepBar := _bi
            _sweptPrice := _ssl
            _sweepExtreme := _l

            // FIX DOL: lock direction, target, start bar, and structural extreme.
            _dolDirLocked := 1
            _dolTargetLocked := _bsl
            _dolStartBar := _bi
            _sweepExtremeLocked := _l
            _dolState := 1

        else if _bslSweepNow and not _sslSweepNow and not na(_ssl)
            _lastSweepDir := -1
            _lastSweepBar := _bi
            _sweptPrice := _bsl
            _sweepExtreme := _h

            // FIX DOL: lock direction, target, start bar, and structural extreme.
            _dolDirLocked := -1
            _dolTargetLocked := _ssl
            _dolStartBar := _bi
            _sweepExtremeLocked := _h
            _dolState := 1

    _sweepFresh = not na(_lastSweepBar) and _bi - _lastSweepBar < _freshBars
    _sweepOld = not na(_lastSweepBar) and _bi - _lastSweepBar >= _freshBars

    // Sweep output exposes terminal Invalid(3), Expired(4), and Abandoned(5).
    _sweepStatus = _dolState == 3 ? 3 :
     _dolState == 4 ? 4 :
     _dolState == 5 ? 5 :
     _sweepFresh ? 1 :
     _sweepOld ? 2 :
     0

    // FIX DOL: outputs come from persistent locked state.
    _dolDir = _dolState == 0 ? 0 : _dolDirLocked
    _dolTarget = _dolState == 0 ? na : _dolTargetLocked
    _dolStatus = _dolState
    _dolDistance = na(_dolTarget) ? na : math.abs(_dolTarget - _c)
    _dolAlign = _dolState != 1 or _dolDir == 0 or _biasDir == 0 ? 0 : _dolDir == _biasDir ? 1 : -1

    // FVG creation
    _bullFvgNew = not na(high[3]) and low[1] > high[3]
    _bearFvgNew = not na(low[3]) and high[1] < low[3]

    if _bullFvgNew
        _bullFvgTop := low[1]
        _bullFvgBtm := high[3]
        _bullFvgStatus := 1
        _bullFvgCreatedBar := _bi

    if _bearFvgNew
        _bearFvgTop := low[3]
        _bearFvgBtm := high[1]
        _bearFvgStatus := 1
        _bearFvgCreatedBar := _bi

    // FIX POI: one-bar gate prevents the formation candle from touching itself.
    _bullFvgCanTransition = _bullFvgStatus > 0 and _bullFvgStatus < 4 and not na(_bullFvgCreatedBar) and _bi > _bullFvgCreatedBar
    _bearFvgCanTransition = _bearFvgStatus > 0 and _bearFvgStatus < 4 and not na(_bearFvgCreatedBar) and _bi > _bearFvgCreatedBar

    _bullFvgHigh = not na(_bullFvgTop) and not na(_bullFvgBtm) ? math.max(_bullFvgTop, _bullFvgBtm) : na
    _bullFvgLow = not na(_bullFvgTop) and not na(_bullFvgBtm) ? math.min(_bullFvgTop, _bullFvgBtm) : na
    _bearFvgHigh = not na(_bearFvgTop) and not na(_bearFvgBtm) ? math.max(_bearFvgTop, _bearFvgBtm) : na
    _bearFvgLow = not na(_bearFvgTop) and not na(_bearFvgBtm) ? math.min(_bearFvgTop, _bearFvgBtm) : na
    _bullFvgMid = not na(_bullFvgHigh) and not na(_bullFvgLow) ? (_bullFvgHigh + _bullFvgLow) / 2.0 : na
    _bearFvgMid = not na(_bearFvgHigh) and not na(_bearFvgLow) ? (_bearFvgHigh + _bearFvgLow) / 2.0 : na

    // Touch and mitigation use wick overlap; failure below uses close.
    _bullFvgIntersects = _bullFvgCanTransition and not na(_bullFvgHigh) and not na(_bullFvgLow) and _l <= _bullFvgHigh and _h >= _bullFvgLow
    _bearFvgIntersects = _bearFvgCanTransition and not na(_bearFvgHigh) and not na(_bearFvgLow) and _h >= _bearFvgLow and _l <= _bearFvgHigh
    _bullFvgTouched = _bullFvgStatus == 1 and _bullFvgIntersects
    _bearFvgTouched = _bearFvgStatus == 1 and _bearFvgIntersects
    _bullFvgMitigated = (_bullFvgStatus == 1 or _bullFvgStatus == 2) and _bullFvgIntersects and not na(_bullFvgMid) and _l <= _bullFvgMid
    _bearFvgMitigated = (_bearFvgStatus == 1 or _bearFvgStatus == 2) and _bearFvgIntersects and not na(_bearFvgMid) and _h >= _bearFvgMid

    // FIX POI: monotonic FVG state machine; first touch may go directly Fresh -> Mitigated.
    if _bullFvgCanTransition and not na(_bullFvgLow)
        if _c < _bullFvgLow
            _bullFvgStatus := 4
        else if _bullFvgStatus == 1
            if _bullFvgMitigated
                _bullFvgStatus := 3
            else if _bullFvgTouched
                _bullFvgStatus := 2
        else if _bullFvgStatus == 2 and _bullFvgMitigated
            _bullFvgStatus := 3

    if _bearFvgCanTransition and not na(_bearFvgHigh)
        if _c > _bearFvgHigh
            _bearFvgStatus := 4
        else if _bearFvgStatus == 1
            if _bearFvgMitigated
                _bearFvgStatus := 3
            else if _bearFvgTouched
                _bearFvgStatus := 2
        else if _bearFvgStatus == 2 and _bearFvgMitigated
            _bearFvgStatus := 3

    // OB creation retains the original candle-selection logic.
    _bullDisp = _c > _o and _body > _meanBody * _dispMult and _c > high[2]
    _bearDisp = _c < _o and _body > _meanBody * _dispMult and _c < low[2]

    if _bullDisp
        _bullObTop := close[2] < open[2] ? open[2] : open[1]
        _bullObBtm := close[2] < open[2] ? low[2] : low[1]
        _bullObStatus := 1
        // Created bar is the confirming displacement bar, regardless of [2] or [1] source candle.
        _bullObCreatedBar := _bi

    if _bearDisp
        _bearObTop := close[2] > open[2] ? high[2] : high[1]
        _bearObBtm := close[2] > open[2] ? open[2] : open[1]
        _bearObStatus := 1
        // Created bar is the confirming displacement bar, regardless of [2] or [1] source candle.
        _bearObCreatedBar := _bi

    // FIX POI: one-bar gate for OB transitions.
    _bullObCanTransition = _bullObStatus > 0 and _bullObStatus < 4 and not na(_bullObCreatedBar) and _bi > _bullObCreatedBar
    _bearObCanTransition = _bearObStatus > 0 and _bearObStatus < 4 and not na(_bearObCreatedBar) and _bi > _bearObCreatedBar

    _bullObHighRaw = not na(_bullObTop) and not na(_bullObBtm) ? math.max(_bullObTop, _bullObBtm) : na
    _bullObLowRaw = not na(_bullObTop) and not na(_bullObBtm) ? math.min(_bullObTop, _bullObBtm) : na
    _bearObHighRaw = not na(_bearObTop) and not na(_bearObBtm) ? math.max(_bearObTop, _bearObBtm) : na
    _bearObLowRaw = not na(_bearObTop) and not na(_bearObBtm) ? math.min(_bearObTop, _bearObBtm) : na
    _bullObMid = not na(_bullObHighRaw) and not na(_bullObLowRaw) ? (_bullObHighRaw + _bullObLowRaw) / 2.0 : na
    _bearObMid = not na(_bearObHighRaw) and not na(_bearObLowRaw) ? (_bearObHighRaw + _bearObLowRaw) / 2.0 : na

    // Touch and mitigation use wick overlap; failure below uses close.
    _bullObIntersects = _bullObCanTransition and not na(_bullObHighRaw) and not na(_bullObLowRaw) and _l <= _bullObHighRaw and _h >= _bullObLowRaw
    _bearObIntersects = _bearObCanTransition and not na(_bearObHighRaw) and not na(_bearObLowRaw) and _h >= _bearObLowRaw and _l <= _bearObHighRaw
    _bullObTouched = _bullObStatus == 1 and _bullObIntersects
    _bearObTouched = _bearObStatus == 1 and _bearObIntersects
    _bullObMitigated = (_bullObStatus == 1 or _bullObStatus == 2) and _bullObIntersects and not na(_bullObMid) and _l <= _bullObMid
    _bearObMitigated = (_bearObStatus == 1 or _bearObStatus == 2) and _bearObIntersects and not na(_bearObMid) and _h >= _bearObMid

    // FIX POI: monotonic OB state machine; first touch may go directly Fresh -> Mitigated.
    if _bullObCanTransition and not na(_bullObLowRaw)
        if _c < _bullObLowRaw
            _bullObStatus := 4
        else if _bullObStatus == 1
            if _bullObMitigated
                _bullObStatus := 3
            else if _bullObTouched
                _bullObStatus := 2
        else if _bullObStatus == 2 and _bullObMitigated
            _bullObStatus := 3

    if _bearObCanTransition and not na(_bearObHighRaw)
        if _c > _bearObHighRaw
            _bearObStatus := 4
        else if _bearObStatus == 1
            if _bearObMitigated
                _bearObStatus := 3
            else if _bearObTouched
                _bearObStatus := 2
        else if _bearObStatus == 2 and _bearObMitigated
            _bearObStatus := 3

    // Dealing range
    _rh = not na(_rangeHigh) and not na(_rangeLow) ? math.max(_rangeHigh, _rangeLow) : na
    _rl = not na(_rangeHigh) and not na(_rangeLow) ? math.min(_rangeHigh, _rangeLow) : na
    _rs = not na(_rh) and not na(_rl) ? math.max(_rh - _rl, syminfo.mintick) : na
    _eq = not na(_rs) ? _rl + _rs * 0.50 : na
    _eqLow = not na(_rs) ? _rl + _rs * 0.48 : na
    _eqHigh = not na(_rs) ? _rl + _rs * 0.52 : na

    _priceZone = na(_eqLow) or na(_eqHigh) ? 0 : _c > _eqHigh ? 1 : _c < _eqLow ? -1 : 0
    _locStatus = _biasDir == 1 and _priceZone == -1 ? 1 :
     _biasDir == 1 and _priceZone == 1 ? -1 :
     _biasDir == -1 and _priceZone == 1 ? 1 :
     _biasDir == -1 and _priceZone == -1 ? -1 :
     0

    // Failed POIs are excluded; Fresh, Active, and Mitigated remain observable.
    _bullObActive = _bullObStatus > 0 and _bullObStatus < 4
    _bullFvgActive = _bullFvgStatus > 0 and _bullFvgStatus < 4
    _bearObActive = _bearObStatus > 0 and _bearObStatus < 4
    _bearFvgActive = _bearFvgStatus > 0 and _bearFvgStatus < 4

    _bullObHigh = _bullObActive ? _bullObHighRaw : na
    _bullObLow = _bullObActive ? _bullObLowRaw : na
    _bullFvgHighActive = _bullFvgActive ? _bullFvgHigh : na
    _bullFvgLowActive = _bullFvgActive ? _bullFvgLow : na
    _bearObHigh = _bearObActive ? _bearObHighRaw : na
    _bearObLow = _bearObActive ? _bearObLowRaw : na
    _bearFvgHighActive = _bearFvgActive ? _bearFvgHigh : na
    _bearFvgLowActive = _bearFvgActive ? _bearFvgLow : na

    _bullObDist = _bullObActive ? (_c >= _bullObLow and _c <= _bullObHigh ? 0.0 : math.min(math.abs(_c - _bullObHigh), math.abs(_c - _bullObLow))) : na
    _bullFvgDist = _bullFvgActive ? (_c >= _bullFvgLowActive and _c <= _bullFvgHighActive ? 0.0 : math.min(math.abs(_c - _bullFvgHighActive), math.abs(_c - _bullFvgLowActive))) : na
    _bearObDist = _bearObActive ? (_c >= _bearObLow and _c <= _bearObHigh ? 0.0 : math.min(math.abs(_c - _bearObHigh), math.abs(_c - _bearObLow))) : na
    _bearFvgDist = _bearFvgActive ? (_c >= _bearFvgLowActive and _c <= _bearFvgHighActive ? 0.0 : math.min(math.abs(_c - _bearFvgHighActive), math.abs(_c - _bearFvgLowActive))) : na

    int _poiType = 0
    float _poiHigh = na
    float _poiLow = na
    int _poiStatus = 0
    int _poiCreatedBar = na

    if _biasDir == 1
        if _bullObActive and (not _bullFvgActive or _bullObDist <= _bullFvgDist)
            _poiType := 1
            _poiHigh := _bullObHigh
            _poiLow := _bullObLow
            _poiStatus := _bullObStatus
            _poiCreatedBar := _bullObCreatedBar
        else if _bullFvgActive
            _poiType := 2
            _poiHigh := _bullFvgHighActive
            _poiLow := _bullFvgLowActive
            _poiStatus := _bullFvgStatus
            _poiCreatedBar := _bullFvgCreatedBar

    if _biasDir == -1
        if _bearObActive and (not _bearFvgActive or _bearObDist <= _bearFvgDist)
            _poiType := -1
            _poiHigh := _bearObHigh
            _poiLow := _bearObLow
            _poiStatus := _bearObStatus
            _poiCreatedBar := _bearObCreatedBar
        else if _bearFvgActive
            _poiType := -2
            _poiHigh := _bearFvgHighActive
            _poiLow := _bearFvgLowActive
            _poiStatus := _bearFvgStatus
            _poiCreatedBar := _bearFvgCreatedBar

    // Maturity is separate from lifecycle: an immature POI remains visible but cannot score.
    _poiAgeBars = not na(_poiCreatedBar) ? _bi - _poiCreatedBar : 0
    _poiMature = _poiType != 0 and not na(_poiCreatedBar) and _poiAgeBars >= _poiMinAgeBars

    _poiMid = not na(_poiHigh) and not na(_poiLow) ? (_poiHigh + _poiLow) / 2.0 : na
    _poiDist = not na(_poiHigh) and not na(_poiLow) ? (_c >= _poiLow and _c <= _poiHigh ? 0.0 : math.min(math.abs(_c - _poiHigh), math.abs(_c - _poiLow))) : na
    _poiAlign = _biasDir == 0 or _poiType == 0 ? 0 : (_biasDir == 1 and _poiType > 0) or (_biasDir == -1 and _poiType < 0) ? 1 : -1
    _poiLoc = na(_poiMid) or na(_eqLow) or na(_eqHigh) ? 0 : _poiMid > _eqHigh ? 1 : _poiMid < _eqLow ? -1 : 0
    _poiLocationOk = (_biasDir == 1 and _poiLoc == -1) or (_biasDir == -1 and _poiLoc == 1)

    // Only an ACTIVE DOL can upgrade a POI to Main; terminal DOL states add no confluence.
    _dolActiveAligned = _dolState == 1 and _dolAlign == 1
    _poiPriority = _poiType == 0 or not _poiMature ? 0 : _poiAlign == 1 and _poiLocationOk and _dolActiveAligned ? 2 : _poiAlign == 1 ? 1 : 0

    // Return order remains exactly aligned with the existing request.security unpack.
    [_o, _h, _l, _c, _lastPH, _lastPL, _biasDir, _mssDir, _bullMss, _bearMss, _lockedInvalid, _invalidStatus, _rh, _rl, _eq, _eqLow, _eqHigh, _priceZone, _locStatus, _bsl, _ssl, _lastSweepDir, _sweepStatus, _sweptPrice, _sweepExtreme, _dolDir, _dolTarget, _dolStatus, _dolDistance, _dolAlign, _poiType, _poiHigh, _poiLow, _poiMid, _poiDist, _poiStatus, _poiAlign, _poiLoc, _poiPriority]

[amyDashV2_o15, amyDashV2_h15, amyDashV2_l15, amyDashV2_c15, amyDashV2_protectedHigh, amyDashV2_protectedLow, amyDashV2_biasDir, amyDashV2_mssDir, amyDashV2_bullMssNow, amyDashV2_bearMssNow, amyDashV2_invalidLevel, amyDashV2_invalidStatus, amyDashV2_rangeHigh, amyDashV2_rangeLow, amyDashV2_eq, amyDashV2_eqLow, amyDashV2_eqHigh, amyDashV2_priceZone, amyDashV2_locationStatus, amyDashV2_bsl, amyDashV2_ssl, amyDashV2_sweepDir, amyDashV2_sweepStatus, amyDashV2_sweptPrice, amyDashV2_sweepExtreme, amyDashV2_dolDir, amyDashV2_dolTarget, amyDashV2_dolStatus, amyDashV2_dolDistance, amyDashV2_dolAlign, amyDashV2_poiType, amyDashV2_poiHigh, amyDashV2_poiLow, amyDashV2_poiMid, amyDashV2_poiDistance, amyDashV2_poiStatus, amyDashV2_poiAlign, amyDashV2_poiLocation, amyDashV2_poiPriority] = request.security(syminfo.tickerid, "15", amyDashV2_engine(amyDashV2_swingLen, amyDashV2_sweepFreshBars, amyDashV2_nearInvalidAtr, amyDashV2_dispMult, amyDashV2_minSweepTicks, amyDashV2_poiMinAgeBars), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

amyDashV2_biasText = amyDashV2_biasDir == 1 ? "BULL STRUCTURE" : amyDashV2_biasDir == -1 ? "BEAR STRUCTURE" : "NO CLEAR STRUCTURE"
amyDashV2_arahText = amyDashV2_biasDir == 0 ? "BELUM JELAS" : "DESKRIPTIF"
amyDashV2_mssText = amyDashV2_mssDir == 1 ? "M15 Bullish" : amyDashV2_mssDir == -1 ? "M15 Bearish" : "M15 Neutral"

amyDashV2_sweepText = amyDashV2_sweepDir == 1 ? "SSL Swept" : amyDashV2_sweepDir == -1 ? "BSL Swept" : "None"
amyDashV2_sweepStatusText = amyDashV2_sweepStatus == 1 ? "Fresh" : amyDashV2_sweepStatus == 2 ? "Old" : amyDashV2_sweepStatus == 3 ? "Invalid" : amyDashV2_sweepStatus == 4 ? "Expired" : amyDashV2_sweepStatus == 5 ? "Abandoned" : "None"

amyDashV2_dolText = amyDashV2_dolDir == 1 ? "Draw to BSL" : amyDashV2_dolDir == -1 ? "Draw to SSL" : "Neutral"
amyDashV2_dolStatusText = amyDashV2_dolStatus == 1 ? "Active" : amyDashV2_dolStatus == 2 ? "Reached" : amyDashV2_dolStatus == 3 ? "Invalid" : amyDashV2_dolStatus == 4 ? "Expired" : amyDashV2_dolStatus == 5 ? "Abandoned" : "Neutral"
amyDashV2_dolAlignText = amyDashV2_dolAlign == 1 ? "With Bias" : amyDashV2_dolAlign == -1 ? "Against Bias" : "Neutral"

amyDashV2_poiTypeText = amyDashV2_poiType == 1 ? "Bull OB" : amyDashV2_poiType == 2 ? "Bull FVG" : amyDashV2_poiType == -1 ? "Bear OB" : amyDashV2_poiType == -2 ? "Bear FVG" : "None"
amyDashV2_poiStatusText = amyDashV2_poiStatus == 1 ? "Fresh" : amyDashV2_poiStatus == 2 ? "Active" : amyDashV2_poiStatus == 3 ? "Mitigated" : amyDashV2_poiStatus == 4 ? "Failed" : "None"
amyDashV2_poiAlignText = amyDashV2_poiAlign == 1 ? "With Bias" : amyDashV2_poiAlign == -1 ? "Against Bias" : "Neutral"
amyDashV2_poiLocationText = amyDashV2_poiLocation == 1 ? "Premium" : amyDashV2_poiLocation == -1 ? "Discount" : "EQ Zone"
amyDashV2_poiPriorityText = amyDashV2_poiPriority == 2 ? "Main" : amyDashV2_poiPriority == 1 ? "Secondary" : "Ignore"

amyDashV2_priceLocationText = amyDashV2_priceZone == 1 ? "Premium" : amyDashV2_priceZone == -1 ? "Discount" : "EQ Zone"
amyDashV2_locationStatusText = amyDashV2_locationStatus == 1 ? "Healthy" : amyDashV2_locationStatus == -1 ? "Bad Location" : "Neutral"

amyDashV2_invalidText = amyDashV2_invalidStatus == 2 ? "Invalid" : amyDashV2_invalidStatus == 1 ? "Near Invalid" : amyDashV2_invalidStatus == 0 ? "Valid" : "No Bias"

amyDashV2_reason = ""
amyDashV2_reason := amyDashV2_join(amyDashV2_reason, amyDashV2_mssText)
amyDashV2_reason := amyDashV2_join(amyDashV2_reason, amyDashV2_sweepStatus == 1 ? amyDashV2_sweepText + " Fresh" : "")
amyDashV2_reason := amyDashV2_join(amyDashV2_reason, amyDashV2_dolStatus == 1 ? amyDashV2_dolText + " raw " + amyDashV2_price(amyDashV2_dolTarget) : "")
amyDashV2_reason := amyDashV2_join(amyDashV2_reason, amyDashV2_poiPriority == 2 ? amyDashV2_poiTypeText + " Main" : "")
amyDashV2_reason := amyDashV2_reason == "" ? "Belum ada alasan kuat" : amyDashV2_reason

amyDashV2_headBg = color.new(#07111D, 0)
amyDashV2_keyBg = color.new(#0B1623, 0)
amyDashV2_cellBg = color.new(#050B12, 0)
amyDashV2_buyBg = color.new(color.lime, 25)
amyDashV2_sellBg = color.new(color.red, 22)
amyDashV2_neutralBg = color.new(color.gray, 55)
amyDashV2_warnBg = color.new(color.orange, 20)

amyDashV2_biasBg = amyDashV2_biasDir == 1 ? amyDashV2_buyBg : amyDashV2_biasDir == -1 ? amyDashV2_sellBg : amyDashV2_warnBg
amyDashV2_dolBg = amyDashV2_dolStatus == 3 ? amyDashV2_sellBg : amyDashV2_dolStatus == 5 ? amyDashV2_warnBg : amyDashV2_dolStatus == 4 ? amyDashV2_neutralBg : amyDashV2_dolStatus == 2 ? amyDashV2_warnBg : amyDashV2_dolDir == 1 ? amyDashV2_buyBg : amyDashV2_dolDir == -1 ? amyDashV2_sellBg : amyDashV2_neutralBg
amyDashV2_invalidBg = amyDashV2_invalidStatus == 2 ? amyDashV2_sellBg : amyDashV2_invalidStatus == 1 ? amyDashV2_warnBg : amyDashV2_invalidStatus == 0 ? amyDashV2_buyBg : amyDashV2_neutralBg
amyDashV2_locBg = amyDashV2_locationStatus == 1 ? amyDashV2_buyBg : amyDashV2_locationStatus == -1 ? amyDashV2_warnBg : amyDashV2_neutralBg
amyDashV2_poiBg = amyDashV2_poiPriority == 2 ? (amyDashV2_poiType > 0 ? amyDashV2_buyBg : amyDashV2_sellBg) : amyDashV2_poiPriority == 1 ? amyDashV2_warnBg : amyDashV2_neutralBg

var table amyDashV2_table = table.new(position.top_right, 2, 16, bgcolor=color.new(color.black, 5), border_width=1, border_color=color.new(color.gray, 55))
var string amyDashV2_lastPosInput = ""

if amyDashV2_show and barstate.islast
    if amyDashV2_lastPosInput != amyDashV2_posInput
        table.delete(amyDashV2_table)
        amyDashV2_table := table.new(amyDashV2_pos(amyDashV2_posInput), 2, 16, bgcolor=color.new(color.black, 5), border_width=1, border_color=color.new(color.gray, 55))
        amyDashV2_lastPosInput := amyDashV2_posInput
    table.set_position(amyDashV2_table, amyDashV2_pos(amyDashV2_posInput))
    table.clear(amyDashV2_table, 0, 0, 1, 15)

    table.cell(amyDashV2_table, 0, 0, "AMY MARKET CONTEXT V4", text_color=color.white, bgcolor=amyDashV2_headBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 0, "M15 CLOSED", text_color=color.white, bgcolor=amyDashV2_headBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 1, "RAW STRUCTURE", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 1, amyDashV2_biasText + " | " + amyDashV2_arahText, text_color=color.white, bgcolor=amyDashV2_biasBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 2, "STRUKTUR", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 2, amyDashV2_mssText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 3, "PROTECTED", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 3, "H " + amyDashV2_price(amyDashV2_protectedHigh) + " | L " + amyDashV2_price(amyDashV2_protectedLow), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 4, "LIQUIDITY", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 4, "BSL " + amyDashV2_price(amyDashV2_bsl) + " | SSL " + amyDashV2_price(amyDashV2_ssl) + " | RAW LEVELS", text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 5, "SWEEP", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 5, amyDashV2_sweepText + " | " + amyDashV2_sweepStatusText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 6, "SWEEP PRICE", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 6, "Swept " + amyDashV2_price(amyDashV2_sweptPrice) + " | Extreme " + amyDashV2_price(amyDashV2_sweepExtreme), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 7, "DOL", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 7, amyDashV2_dolText + " @ " + amyDashV2_price(amyDashV2_dolTarget) + " | " + amyDashV2_dolStatusText, text_color=color.white, bgcolor=amyDashV2_dolBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 8, "DOL DETAIL", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 8, "Dist " + amyDashV2_price(amyDashV2_dolDistance) + " | " + amyDashV2_dolAlignText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 9, "POI", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 9, amyDashV2_poiTypeText + " | " + amyDashV2_poiStatusText + " | " + amyDashV2_poiPriorityText + " | OBS", text_color=color.white, bgcolor=amyDashV2_poiBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 10, "POI PRICE", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 10, amyDashV2_range(amyDashV2_poiHigh, amyDashV2_poiLow) + " | CE " + amyDashV2_price(amyDashV2_poiMid), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 11, "POI DETAIL", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 11, "Dist " + amyDashV2_price(amyDashV2_poiDistance) + " | " + amyDashV2_poiAlignText + " | " + amyDashV2_poiLocationText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 12, "POSISI", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 12, amyDashV2_priceLocationText + " | " + amyDashV2_locationStatusText, text_color=color.white, bgcolor=amyDashV2_locBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 13, "RANGE", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 13, "H " + amyDashV2_price(amyDashV2_rangeHigh) + " | L " + amyDashV2_price(amyDashV2_rangeLow) + " | EQ " + amyDashV2_range(amyDashV2_eqHigh, amyDashV2_eqLow), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 14, "INVALID", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 14, amyDashV2_invalidText + " | Level " + amyDashV2_price(amyDashV2_invalidLevel) + " | Dist " + amyDashV2_dist(amyDashV2_invalidLevel, amyDashV2_c15), text_color=color.white, bgcolor=amyDashV2_invalidBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 15, "ALASAN INTI", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 15, amyDashV2_clip(amyDashV2_reason, 85), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

if not amyDashV2_show and barstate.islast
    table.clear(amyDashV2_table, 0, 0, 1, 15)

//==================== AMY ASSISTANT V4 — VALIDATED CLAIMS + OBSERVATION ====================//
amyEntryV2_group = "AMY Assistant V4"
amyEntryV2_show = input.bool(true, "Show Entry Assistant", group=amyEntryV2_group)
amyEntryV2_showChartNotes = input.bool(true, "Show Chart Narration", group=amyEntryV2_group)
amyEntryV2_showPanel = input.bool(false, "Show Assistant Panel", group=amyEntryV2_group)
amyEntryV2_showValidatedMarkers = input.bool(true, "Show Validated Claim Markers", group=amyEntryV2_group)
amyEntryV2_triggerTf = input.timeframe("5", "Trigger Confirmation TF", group=amyEntryV2_group)
amyEntryV2_swingLen = input.int(3, "Trigger Swing Length", minval=1, maxval=10, group=amyEntryV2_group)
amyEntryV2_dispMult = input.float(1.0, "Trigger Displacement Body Mult", minval=0.5, maxval=3.0, step=0.1, group=amyEntryV2_group)
amyEntryV2_rejectWickMult = input.float(1.25, "POI Rejection Wick Mult", minval=0.5, maxval=5.0, step=0.05, group=amyEntryV2_group)
amyEntryV2_noteOffsetAtr = input.float(0.70, "Chart Note Offset ATR", minval=0.10, maxval=3.0, step=0.05, group=amyEntryV2_group)
amyEntryV2_minScore = input.int(40, "Minimum Score to Show", minval=10, maxval=90, step=5, group=amyEntryV2_group)

// Locked validation thresholds from the 2020-2025 non-repaint backtest.
// Do not expose these as tuning inputs: changing them invalidates the measured accuracy.
amyEntryV2_validatedDolMaxAtr = 0.75
amyEntryV2_validatedDolMinScore = 50
amyEntryV3_validatedRiskMaxAtr = 1.50
amyContextV4_keyLiquidityMaxAtr = 1.50
amyContextV4_pdhPdlMaxAtr = 3.00
amyContextV4_asiaTargetMaxAtr = 2.00
amyContextV4_poiRevisitMaxAtr = 1.50
amyContextV4_asiaEntryMinAtr = 0.35
amyContextV4_asiaEntryMaxAtr = 1.50
amyContextV4_asiaEntryRewardRisk = 0.20
amyContextV4_oneHourBars = 12
amyContextV4_fourHoursBars = 48
amyContextV4_eightHoursBars = 96

amyEntryV2_price(_x) =>
    na(_x) ? "-" : str.tostring(_x, format.mintick)

amyEntryV2_poiName(_type) =>
    _type == 1 ? "Bull OB" :
     _type == 2 ? "Bull FVG" :
     _type == -1 ? "Bear OB" :
     _type == -2 ? "Bear FVG" :
     "POI"

amyEntryV2_dolName(_dir) =>
    _dir == 1 ? "BSL" : _dir == -1 ? "SSL" : "liquidity"

amyEntryV2_dirName(_dir) =>
    _dir == 1 ? "BUY" : _dir == -1 ? "SELL" : "—"

// === LTF Confirmation Engine (Anti-Repaint: semua data dari closed bars) ===
amyEntryV2_ltfEngine(_swingLen, _dispMult, _rejectWickMult) =>
    var float _lastHigh = na
    var float _lastLow = na

    _ph = ta.pivothigh(high, _swingLen, _swingLen)
    _pl = ta.pivotlow(low, _swingLen, _swingLen)

    if not na(_ph)
        _lastHigh := _ph

    if not na(_pl)
        _lastLow := _pl

    _body = math.abs(close - open)
    _meanBody = ta.sma(math.abs(close - open), 20)
    _safeBody = math.max(_body, syminfo.mintick)
    _upperWick = high - math.max(open, close)
    _lowerWick = math.min(open, close) - low

    _sslSweep = not na(_lastLow) and low < _lastLow and close > _lastLow
    _bslSweep = not na(_lastHigh) and high > _lastHigh and close < _lastHigh
    _sweepDir = _sslSweep and not _bslSweep ? 1 : _bslSweep and not _sslSweep ? -1 : 0
    _sweptPrice = _sweepDir == 1 ? _lastLow : _sweepDir == -1 ? _lastHigh : na
    _sweepExtreme = _sweepDir == 1 ? low : _sweepDir == -1 ? high : na

    _bullBreak = not na(_lastHigh) and close > _lastHigh
    _bearBreak = not na(_lastLow) and close < _lastLow
    _bullDisp = close > open and _body > _meanBody * _dispMult and close > high[1]
    _bearDisp = close < open and _body > _meanBody * _dispMult and close < low[1]
    _bullReject = close > open and _lowerWick >= _safeBody * _rejectWickMult
    _bearReject = close < open and _upperWick >= _safeBody * _rejectWickMult

    [_lastHigh, _lastLow, _sweepDir, _sweptPrice, _sweepExtreme, _bullBreak, _bearBreak, _bullDisp, _bearDisp, _bullReject, _bearReject, close]

[amyEntryV2_ltfHigh, amyEntryV2_ltfLow, amyEntryV2_ltfSweepDir, amyEntryV2_ltfSweptPrice, amyEntryV2_ltfSweepExtreme, amyEntryV2_ltfBullBreak, amyEntryV2_ltfBearBreak, amyEntryV2_ltfBullDisp, amyEntryV2_ltfBearDisp, amyEntryV2_ltfBullReject, amyEntryV2_ltfBearReject, amyEntryV2_ltfClose] = request.security(syminfo.tickerid, amyEntryV2_triggerTf, amyEntryV2_ltfEngine(amyEntryV2_swingLen, amyEntryV2_dispMult, amyEntryV2_rejectWickMult), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// === Existing condition checks ===
amyEntryV2_biasActive = amyEntryV2_show and amyDashV2_biasDir != 0 and (amyDashV2_invalidStatus == 0 or amyDashV2_invalidStatus == 1)
amyEntryV2_poiReady = amyDashV2_poiPriority >= 1 and amyDashV2_poiAlign == 1 and amyDashV2_poiStatus >= 1 and amyDashV2_poiStatus <= 3 and not na(amyDashV2_poiHigh) and not na(amyDashV2_poiLow)
amyEntryV2_inPoi = amyEntryV2_poiReady and high >= amyDashV2_poiLow and low <= amyDashV2_poiHigh

amyEntryV2_body = math.abs(close - open)
amyEntryV2_safeBody = math.max(amyEntryV2_body, syminfo.mintick)
amyEntryV2_upperWick = high - math.max(open, close)
amyEntryV2_lowerWick = math.min(open, close) - low

amyEntryV2_bullPoiReject = amyEntryV2_biasActive and amyDashV2_biasDir == 1 and amyEntryV2_inPoi and close > open and amyEntryV2_lowerWick >= amyEntryV2_safeBody * amyEntryV2_rejectWickMult
amyEntryV2_bearPoiReject = amyEntryV2_biasActive and amyDashV2_biasDir == -1 and amyEntryV2_inPoi and close < open and amyEntryV2_upperWick >= amyEntryV2_safeBody * amyEntryV2_rejectWickMult

amyEntryV2_ltfSweepAligned = amyEntryV2_biasActive and amyEntryV2_ltfSweepDir == amyDashV2_biasDir and amyEntryV2_ltfSweepDir != 0

// =====================================================================
// MULTI-LAYER CONFLUENCE SCORING ENGINE (Non-Repaint)
// Semua data dari closed candles — tidak ada sinyal yang berubah
// setelah candle close.
// =====================================================================

// --- Layer 1: M15 Bias Direction (max 20 pts) ---
amyEntryV2_bullBias = amyDashV2_biasDir == 1 ? 20 : 0
amyEntryV2_bearBias = amyDashV2_biasDir == -1 ? 20 : 0

// --- Layer 2: Liquidity Sweep (max 20 pts) ---
// Fresh sweep = 20, Old sweep = 8, No sweep = 0
amyEntryV2_bullSweep = amyDashV2_sweepStatus == 1 and amyDashV2_sweepDir == 1 ? 20 :
 amyDashV2_sweepStatus == 2 and amyDashV2_sweepDir == 1 ? 8 :
 amyEntryV2_ltfSweepDir == 1 ? 12 : 0
amyEntryV2_bearSweep = amyDashV2_sweepStatus == 1 and amyDashV2_sweepDir == -1 ? 20 :
 amyDashV2_sweepStatus == 2 and amyDashV2_sweepDir == -1 ? 8 :
 amyEntryV2_ltfSweepDir == -1 ? 12 : 0

// --- Layer 3: Mature POI Alignment (max 10 pts) ---
// Fresh is potential only, Active has confirmed interaction, Mitigated has residual value.
// Immature POIs are already blocked by amyDashV2_poiPriority == 0.
amyEntryV2_bullPoi = amyDashV2_poiPriority >= 1 and amyDashV2_poiAlign == 1 and amyDashV2_biasDir == 1 ?
 (amyDashV2_poiStatus == 1 ? (amyDashV2_poiLocation == -1 ? 6 : 3) :
  amyDashV2_poiStatus == 2 ? (amyDashV2_poiLocation == -1 ? 10 : 5) :
  amyDashV2_poiStatus == 3 ? (amyDashV2_poiLocation == -1 ? 3 : 1) : 0) : 0
amyEntryV2_bearPoi = amyDashV2_poiPriority >= 1 and amyDashV2_poiAlign == 1 and amyDashV2_biasDir == -1 ?
 (amyDashV2_poiStatus == 1 ? (amyDashV2_poiLocation == 1 ? 6 : 3) :
  amyDashV2_poiStatus == 2 ? (amyDashV2_poiLocation == 1 ? 10 : 5) :
  amyDashV2_poiStatus == 3 ? (amyDashV2_poiLocation == 1 ? 3 : 1) : 0) : 0

// Bonus: Rejection dari POI (+5)
amyEntryV2_bullPoiBonus = amyEntryV2_bullPoiReject ? 5 : (amyEntryV2_inPoi and amyDashV2_biasDir == 1 ? 3 : 0)
amyEntryV2_bearPoiBonus = amyEntryV2_bearPoiReject ? 5 : (amyEntryV2_inPoi and amyDashV2_biasDir == -1 ? 3 : 0)

// --- Layer 4: DOL Active (max 10 pts) ---
// Only Active(1) contributes directional confluence.
// Reached/Invalid/Expired/Abandoned are terminal and must not keep adding score.
amyEntryV2_bullDol = amyDashV2_dolStatus == 1 and amyDashV2_dolDir == 1 ? 10 : 0
amyEntryV2_bearDol = amyDashV2_dolStatus == 1 and amyDashV2_dolDir == -1 ? 10 : 0

// --- Layer 5: Price Location / Zone (max 10 pts) ---
// Buy dari discount = 10, EQ = 3, Premium = 0
// Sell dari premium = 10, EQ = 3, Discount = 0
amyEntryV2_bullLoc = amyDashV2_priceZone == -1 ? 10 : amyDashV2_priceZone == 0 ? 3 : 0
amyEntryV2_bearLoc = amyDashV2_priceZone == 1 ? 10 : amyDashV2_priceZone == 0 ? 3 : 0

// --- Layer 6: LTF Displacement (max 15 pts) ---
amyEntryV2_bullDisp = amyEntryV2_ltfBullDisp ? 15 : 0
amyEntryV2_bearDisp = amyEntryV2_ltfBearDisp ? 15 : 0

// --- Layer 7: LTF Structure Break (max 10 pts) ---
amyEntryV2_bullBreak = amyEntryV2_ltfBullBreak ? 10 : 0
amyEntryV2_bearBreak = amyEntryV2_ltfBearBreak ? 10 : 0

// --- Layer 8: Asia Session Context (max 5 pts) ---
// Bounce dari Asia Low = bullish, Reject dari Asia High = bearish
amyEntryV2_bullAsia = not na(amyKeyV2_asiaLow) and low <= amyKeyV2_asiaLow and close > amyKeyV2_asiaLow ? 5 :
 not na(amyKeyV2_asiaHigh) and close > amyKeyV2_asiaHigh ? 3 : 0
amyEntryV2_bearAsia = not na(amyKeyV2_asiaHigh) and high >= amyKeyV2_asiaHigh and close < amyKeyV2_asiaHigh ? 5 :
 not na(amyKeyV2_asiaLow) and close < amyKeyV2_asiaLow ? 3 : 0

// === TOTAL SCORE (max ~105 with bonuses, capped display at 100) ===
amyEntryV2_rawBullScore = amyEntryV2_bullBias + amyEntryV2_bullSweep + amyEntryV2_bullPoi + amyEntryV2_bullPoiBonus + amyEntryV2_bullDol + amyEntryV2_bullLoc + amyEntryV2_bullDisp + amyEntryV2_bullBreak + amyEntryV2_bullAsia
amyEntryV2_rawBearScore = amyEntryV2_bearBias + amyEntryV2_bearSweep + amyEntryV2_bearPoi + amyEntryV2_bearPoiBonus + amyEntryV2_bearDol + amyEntryV2_bearLoc + amyEntryV2_bearDisp + amyEntryV2_bearBreak + amyEntryV2_bearAsia

amyEntryV2_bullScore = math.min(amyEntryV2_rawBullScore, 100)
amyEntryV2_bearScore = math.min(amyEntryV2_rawBearScore, 100)

// === Penalty: Invalid status mengurangi skor ===
amyEntryV2_bullScoreFinal = amyDashV2_invalidStatus == 2 ? 0 : amyDashV2_invalidStatus == 1 ? math.round(amyEntryV2_bullScore * 0.7) : amyEntryV2_bullScore
amyEntryV2_bearScoreFinal = amyDashV2_invalidStatus == 2 ? 0 : amyDashV2_invalidStatus == 1 ? math.round(amyEntryV2_bearScore * 0.7) : amyEntryV2_bearScore

// === Determine winning direction ===
amyEntryV2_winDir = amyEntryV2_bullScoreFinal > amyEntryV2_bearScoreFinal ? 1 : amyEntryV2_bearScoreFinal > amyEntryV2_bullScoreFinal ? -1 : 0
amyEntryV2_winScore = amyEntryV2_winDir == 1 ? amyEntryV2_bullScoreFinal : amyEntryV2_winDir == -1 ? amyEntryV2_bearScoreFinal : 0

// === Proximity detection ===
amyEntryV2_atr14 = ta.atr(14)
amyEntryV2_poiMid = not na(amyDashV2_poiHigh) and not na(amyDashV2_poiLow) ? (amyDashV2_poiHigh + amyDashV2_poiLow) / 2.0 : na
amyEntryV2_poiDist = not na(amyDashV2_poiHigh) and not na(amyDashV2_poiLow) ?
 (close >= amyDashV2_poiLow and close <= amyDashV2_poiHigh ? 0.0 :
 math.min(math.abs(close - amyDashV2_poiHigh), math.abs(close - amyDashV2_poiLow))) : na
amyEntryV2_nearPoi = not na(amyEntryV2_poiDist) and amyEntryV2_poiDist > 0 and amyEntryV2_poiDist <= amyEntryV2_atr14 * 1.5 and amyEntryV2_poiReady

// Asia proximity
amyEntryV2_nearAsiaH = not na(amyKeyV2_asiaHigh) and math.abs(close - amyKeyV2_asiaHigh) <= amyEntryV2_atr14 * 0.8 and close != amyKeyV2_asiaHigh
amyEntryV2_nearAsiaL = not na(amyKeyV2_asiaLow) and math.abs(close - amyKeyV2_asiaLow) <= amyEntryV2_atr14 * 0.8 and close != amyKeyV2_asiaLow
amyEntryV2_touchAsiaH = not na(amyKeyV2_asiaHigh) and high >= amyKeyV2_asiaHigh and low <= amyKeyV2_asiaHigh
amyEntryV2_touchAsiaL = not na(amyKeyV2_asiaLow) and high >= amyKeyV2_asiaLow and low <= amyKeyV2_asiaLow
amyEntryV2_breakAboveAsiaH = not na(amyKeyV2_asiaHigh) and close > amyKeyV2_asiaHigh and close[1] <= amyKeyV2_asiaHigh
amyEntryV2_breakBelowAsiaL = not na(amyKeyV2_asiaLow) and close < amyKeyV2_asiaLow and close[1] >= amyKeyV2_asiaLow

// DOL proximity
amyEntryV2_dolDist = not na(amyDashV2_dolTarget) ? math.abs(close - amyDashV2_dolTarget) : na
amyEntryV2_nearDol = not na(amyEntryV2_dolDist) and amyEntryV2_dolDist <= amyEntryV2_atr14 * 1.0 and amyDashV2_dolStatus == 1

// === VALIDATED DOL FILTER ===
// The quality decision is made once, on the first M5 display bar of a new Active DOL,
// then locked for that DOL. It cannot become validated later merely because price moved closer.
amyEntryV2_dolDirectionScore = amyDashV2_dolDir == 1 ? amyEntryV2_bullScoreFinal : amyDashV2_dolDir == -1 ? amyEntryV2_bearScoreFinal : 0
amyEntryV2_dolActiveEvent = amyDashV2_dolStatus == 1 and (amyDashV2_dolStatus[1] != 1 or amyDashV2_dolDir != amyDashV2_dolDir[1] or amyDashV2_dolTarget != amyDashV2_dolTarget[1])
amyEntryV2_dolTargetUntouched = amyDashV2_dolDir == 1 and not na(amyDashV2_dolTarget) ? high < amyDashV2_dolTarget :
 amyDashV2_dolDir == -1 and not na(amyDashV2_dolTarget) ? low > amyDashV2_dolTarget :
 false
amyEntryV2_dolQualityAtStart = amyEntryV2_dolActiveEvent and
 not na(amyEntryV2_dolDist) and not na(amyEntryV2_atr14) and
 amyEntryV2_dolDist <= amyEntryV2_atr14 * amyEntryV2_validatedDolMaxAtr and
 amyEntryV2_dolDirectionScore >= amyEntryV2_validatedDolMinScore and
 amyEntryV2_dolTargetUntouched and amyDashV2_invalidStatus != 2

var bool amyEntryV2_dolQualityLocked = false
if amyEntryV2_dolActiveEvent
    amyEntryV2_dolQualityLocked := amyEntryV2_dolQualityAtStart
else if amyDashV2_dolStatus != 1
    amyEntryV2_dolQualityLocked := false

amyEntryV2_dolValidated = amyDashV2_dolStatus == 1 and amyEntryV2_dolQualityLocked
amyEntryV2_dolValidatedEvent = amyEntryV2_dolValidated and not amyEntryV2_dolValidated[1]

// Terminal DOL states are persistent, so narration must fire only on transition.
amyEntryV2_dolReachedEvent = amyDashV2_dolStatus == 2 and amyDashV2_dolStatus[1] != 2
amyEntryV2_dolInvalidEvent = amyDashV2_dolStatus == 3 and amyDashV2_dolStatus[1] != 3
amyEntryV2_dolExpiredEvent = amyDashV2_dolStatus == 4 and amyDashV2_dolStatus[1] != 4
amyEntryV2_dolAbandonedEvent = amyDashV2_dolStatus == 5 and amyDashV2_dolStatus[1] != 5

// Invalid proximity
amyEntryV2_invDist = not na(amyDashV2_invalidLevel) ? math.abs(close - amyDashV2_invalidLevel) : na
amyEntryV2_nearInvalid = not na(amyEntryV2_invDist) and amyEntryV2_invDist <= amyEntryV2_atr14 * 0.6

// === ASSISTANT V3 CLAIM LOCKS ===
// Risk quality is evaluated once, on the first M5 display bar of a new Near Invalid state.
// It cannot become validated later merely because price moved closer to invalidation.
amyEntryV3_rawRiskEvent = amyDashV2_invalidStatus == 1 and
 (amyDashV2_invalidStatus[1] != 1 or amyDashV2_biasDir != amyDashV2_biasDir[1] or amyDashV2_invalidLevel != amyDashV2_invalidLevel[1])
amyEntryV3_riskQualityAtStart = amyEntryV3_rawRiskEvent and
 not na(amyEntryV2_invDist) and not na(amyEntryV2_atr14) and
 amyEntryV2_invDist <= amyEntryV2_atr14 * amyEntryV3_validatedRiskMaxAtr

var bool amyEntryV3_riskQualityLocked = false
if amyEntryV3_rawRiskEvent
    amyEntryV3_riskQualityLocked := amyEntryV3_riskQualityAtStart
else if amyDashV2_invalidStatus != 1
    amyEntryV3_riskQualityLocked := false

amyEntryV3_validatedRisk = amyDashV2_invalidStatus == 1 and amyEntryV3_riskQualityLocked
amyEntryV3_validatedRiskEvent = amyEntryV3_rawRiskEvent and amyEntryV3_riskQualityAtStart

// A target claim is also decided only at DOL start. If Near Invalid was already active,
// that DOL remains observation-only even if the risk state clears later.
amyEntryV3_targetQualityAtStart = amyEntryV2_dolActiveEvent and amyEntryV2_dolQualityAtStart and amyDashV2_invalidStatus == 0
var bool amyEntryV3_targetQualityLocked = false
if amyEntryV2_dolActiveEvent
    amyEntryV3_targetQualityLocked := amyEntryV3_targetQualityAtStart
else if amyDashV2_dolStatus != 1
    amyEntryV3_targetQualityLocked := false

amyEntryV3_validatedTarget = amyDashV2_dolStatus == 1 and amyEntryV3_targetQualityLocked
amyEntryV3_validatedTargetEvent = amyEntryV2_dolActiveEvent and amyEntryV3_targetQualityAtStart

// =====================================================================
// MARKET CONTEXT V4 — LOCKED VALIDATION FOR THE REMAINING CONTEXT
// All thresholds and horizons below are fixed from the 2020-2025 M5 test.
// A displayed level remains observation-only unless its one-time event passes.
// =====================================================================
amyContextV4_isM5 = timeframe.isminutes and timeframe.multiplier == 5
amyContextV4_nyHour = hour(time, "America/New_York")
amyContextV4_nyMinute = minute(time, "America/New_York")
amyContextV4_midnightEvent = amyContextV4_isM5 and barstate.isconfirmed and amyContextV4_nyHour == 0 and amyContextV4_nyMinute == 0

// --- Protected structure hold: one-hour validity claim at each new raw bias episode ---
amyContextV4_protectedEvent = amyContextV4_isM5 and barstate.isconfirmed and amyDashV2_biasDir != 0 and
 (amyDashV2_biasDir != amyDashV2_biasDir[1] or amyDashV2_invalidLevel != amyDashV2_invalidLevel[1])
var int amyContextV4_protectedState = 0  // 0 none, 1 active, 2 held, 3 failed
var int amyContextV4_protectedStartBar = na
var int amyContextV4_protectedDir = 0
var float amyContextV4_protectedLevel = na
if amyContextV4_protectedEvent
    amyContextV4_protectedState := 1
    amyContextV4_protectedStartBar := bar_index
    amyContextV4_protectedDir := amyDashV2_biasDir
    amyContextV4_protectedLevel := amyDashV2_invalidLevel
else if amyContextV4_protectedState == 1
    if amyDashV2_biasDir != amyContextV4_protectedDir
        amyContextV4_protectedState := 3
    else if bar_index - amyContextV4_protectedStartBar >= amyContextV4_oneHourBars
        amyContextV4_protectedState := 2
amyContextV4_protectedActive = amyContextV4_protectedState == 1

// --- M5 key-liquidity target: nearest untouched BSL/SSL after a level refresh ---
amyContextV4_keyBslValid = not na(amyKeyV2_bsl) and amyKeyV2_bsl > high
amyContextV4_keySslValid = not na(amyKeyV2_ssl) and amyKeyV2_ssl < low
amyContextV4_keyBslDist = amyContextV4_keyBslValid ? amyKeyV2_bsl - close : na
amyContextV4_keySslDist = amyContextV4_keySslValid ? close - amyKeyV2_ssl : na
amyContextV4_keyLiquidityDir = amyContextV4_keyBslValid and (not amyContextV4_keySslValid or amyContextV4_keyBslDist <= amyContextV4_keySslDist) ? 1 : amyContextV4_keySslValid ? -1 : 0
amyContextV4_keyLiquidityCandidate = amyContextV4_keyLiquidityDir == 1 ? amyKeyV2_bsl : amyContextV4_keyLiquidityDir == -1 ? amyKeyV2_ssl : na
amyContextV4_keyLiquidityDistAtr = amyContextV4_keyLiquidityDir != 0 and not na(amyEntryV2_atr14) ? math.abs(amyContextV4_keyLiquidityCandidate - close) / amyEntryV2_atr14 : na
amyContextV4_keyLiquidityRefresh = amyContextV4_isM5 and barstate.isconfirmed and
 (amyKeyV2_bsl != amyKeyV2_bsl[1] or amyKeyV2_ssl != amyKeyV2_ssl[1] or amyDashV2_biasDir != amyDashV2_biasDir[1])
var int amyContextV4_lastKeyLiquidityDir = 0
var float amyContextV4_lastKeyLiquidityTarget = na
amyContextV4_keyLiquidityEvent = false
if amyContextV4_keyLiquidityRefresh and amyContextV4_keyLiquidityDir != 0
    _keyChanged = amyContextV4_keyLiquidityDir != amyContextV4_lastKeyLiquidityDir or amyContextV4_keyLiquidityCandidate != amyContextV4_lastKeyLiquidityTarget
    amyContextV4_lastKeyLiquidityDir := amyContextV4_keyLiquidityDir
    amyContextV4_lastKeyLiquidityTarget := amyContextV4_keyLiquidityCandidate
    amyContextV4_keyLiquidityEvent := _keyChanged and not na(amyContextV4_keyLiquidityDistAtr) and amyContextV4_keyLiquidityDistAtr <= amyContextV4_keyLiquidityMaxAtr
var int amyContextV4_keyLiquidityState = 0
var int amyContextV4_keyLiquidityStartBar = na
var int amyContextV4_keyLiquidityLockedDir = 0
var float amyContextV4_keyLiquidityLockedTarget = na
if amyContextV4_keyLiquidityEvent
    amyContextV4_keyLiquidityState := 1
    amyContextV4_keyLiquidityStartBar := bar_index
    amyContextV4_keyLiquidityLockedDir := amyContextV4_keyLiquidityDir
    amyContextV4_keyLiquidityLockedTarget := amyContextV4_keyLiquidityCandidate
else if amyContextV4_keyLiquidityState == 1
    _keyHit = amyContextV4_keyLiquidityLockedDir == 1 ? high >= amyContextV4_keyLiquidityLockedTarget : low <= amyContextV4_keyLiquidityLockedTarget
    if _keyHit
        amyContextV4_keyLiquidityState := 2
    else if bar_index - amyContextV4_keyLiquidityStartBar >= amyContextV4_fourHoursBars
        amyContextV4_keyLiquidityState := 3
amyContextV4_keyLiquidityActive = amyContextV4_keyLiquidityState == 1

// --- Previous-day liquidity: nearest untouched PDH/PDL, eight-hour claim ---
amyContextV4_pdhValid = not na(amyKeyV2_pdh) and amyKeyV2_pdh > high
amyContextV4_pdlValid = not na(amyKeyV2_pdl) and amyKeyV2_pdl < low
amyContextV4_pdhDist = amyContextV4_pdhValid ? amyKeyV2_pdh - close : na
amyContextV4_pdlDist = amyContextV4_pdlValid ? close - amyKeyV2_pdl : na
amyContextV4_pdhPdlDir = amyContextV4_pdhValid and (not amyContextV4_pdlValid or amyContextV4_pdhDist <= amyContextV4_pdlDist) ? 1 : amyContextV4_pdlValid ? -1 : 0
amyContextV4_pdhPdlCandidate = amyContextV4_pdhPdlDir == 1 ? amyKeyV2_pdh : amyContextV4_pdhPdlDir == -1 ? amyKeyV2_pdl : na
amyContextV4_pdhPdlDistAtr = amyContextV4_pdhPdlDir != 0 and not na(amyEntryV2_atr14) ? math.abs(amyContextV4_pdhPdlCandidate - close) / amyEntryV2_atr14 : na
amyContextV4_pdhPdlEvent = amyContextV4_midnightEvent and amyContextV4_pdhPdlDir != 0 and not na(amyContextV4_pdhPdlDistAtr) and amyContextV4_pdhPdlDistAtr <= amyContextV4_pdhPdlMaxAtr
var int amyContextV4_pdhPdlState = 0
var int amyContextV4_pdhPdlStartBar = na
var int amyContextV4_pdhPdlLockedDir = 0
var float amyContextV4_pdhPdlLockedTarget = na
if amyContextV4_pdhPdlEvent
    amyContextV4_pdhPdlState := 1
    amyContextV4_pdhPdlStartBar := bar_index
    amyContextV4_pdhPdlLockedDir := amyContextV4_pdhPdlDir
    amyContextV4_pdhPdlLockedTarget := amyContextV4_pdhPdlCandidate
else if amyContextV4_pdhPdlState == 1
    _pdHit = amyContextV4_pdhPdlLockedDir == 1 ? high >= amyContextV4_pdhPdlLockedTarget : low <= amyContextV4_pdhPdlLockedTarget
    if _pdHit
        amyContextV4_pdhPdlState := 2
    else if bar_index - amyContextV4_pdhPdlStartBar >= amyContextV4_eightHoursBars
        amyContextV4_pdhPdlState := 3
amyContextV4_pdhPdlActive = amyContextV4_pdhPdlState == 1

// --- Asia liquidity: nearest untouched locked boundary, four-hour claim ---
amyContextV4_asiaHighValid = not na(amyKeyV2_asiaHigh) and amyKeyV2_asiaHigh > high
amyContextV4_asiaLowValid = not na(amyKeyV2_asiaLow) and amyKeyV2_asiaLow < low
amyContextV4_asiaHighDist = amyContextV4_asiaHighValid ? amyKeyV2_asiaHigh - close : na
amyContextV4_asiaLowDist = amyContextV4_asiaLowValid ? close - amyKeyV2_asiaLow : na
amyContextV4_asiaDir = amyContextV4_asiaHighValid and (not amyContextV4_asiaLowValid or amyContextV4_asiaHighDist <= amyContextV4_asiaLowDist) ? 1 : amyContextV4_asiaLowValid ? -1 : 0
amyContextV4_asiaCandidate = amyContextV4_asiaDir == 1 ? amyKeyV2_asiaHigh : amyContextV4_asiaDir == -1 ? amyKeyV2_asiaLow : na
amyContextV4_asiaDistAtr = amyContextV4_asiaDir != 0 and not na(amyEntryV2_atr14) ? math.abs(amyContextV4_asiaCandidate - close) / amyEntryV2_atr14 : na
amyContextV4_asiaTargetEvent = amyContextV4_midnightEvent and amyContextV4_asiaDir != 0 and not na(amyContextV4_asiaDistAtr) and amyContextV4_asiaDistAtr <= amyContextV4_asiaTargetMaxAtr
var int amyContextV4_asiaTargetState = 0
var int amyContextV4_asiaTargetStartBar = na
var int amyContextV4_asiaTargetLockedDir = 0
var float amyContextV4_asiaTargetLockedPrice = na
if amyContextV4_asiaTargetEvent
    amyContextV4_asiaTargetState := 1
    amyContextV4_asiaTargetStartBar := bar_index
    amyContextV4_asiaTargetLockedDir := amyContextV4_asiaDir
    amyContextV4_asiaTargetLockedPrice := amyContextV4_asiaCandidate
else if amyContextV4_asiaTargetState == 1
    _asiaHit = amyContextV4_asiaTargetLockedDir == 1 ? high >= amyContextV4_asiaTargetLockedPrice : low <= amyContextV4_asiaTargetLockedPrice
    if _asiaHit
        amyContextV4_asiaTargetState := 2
    else if bar_index - amyContextV4_asiaTargetStartBar >= amyContextV4_fourHoursBars
        amyContextV4_asiaTargetState := 3
amyContextV4_asiaTargetActive = amyContextV4_asiaTargetState == 1

// --- Midnight Open: first fully separated M5 candle of each NY calendar day ---
var bool amyContextV4_moDepartureSeen = false
if amyKeyV2_newDayChart
    amyContextV4_moDepartureSeen := false
amyContextV4_moOutside = not na(amyKeyV2_midnightOpen) and (high < amyKeyV2_midnightOpen or low > amyKeyV2_midnightOpen)
amyContextV4_moEvent = amyContextV4_isM5 and barstate.isconfirmed and not amyContextV4_moDepartureSeen and amyContextV4_moOutside
if amyContextV4_moEvent
    amyContextV4_moDepartureSeen := true
amyContextV4_moDir = close > amyKeyV2_midnightOpen ? -1 : 1
var int amyContextV4_moState = 0
var int amyContextV4_moStartBar = na
var int amyContextV4_moLockedDir = 0
var float amyContextV4_moLockedTarget = na
if amyContextV4_moEvent
    amyContextV4_moState := 1
    amyContextV4_moStartBar := bar_index
    amyContextV4_moLockedDir := amyContextV4_moDir
    amyContextV4_moLockedTarget := amyKeyV2_midnightOpen
else if amyContextV4_moState == 1
    _moHit = amyContextV4_moLockedDir == 1 ? high >= amyContextV4_moLockedTarget : low <= amyContextV4_moLockedTarget
    if _moHit
        amyContextV4_moState := 2
    else if bar_index - amyContextV4_moStartBar >= amyContextV4_fourHoursBars
        amyContextV4_moState := 3
amyContextV4_moActive = amyContextV4_moState == 1

// --- Mature Fresh POI revisit: OB and FVG measured separately ---
amyContextV4_poiFresh = amyDashV2_poiType != 0 and amyDashV2_poiStatus == 1 and amyDashV2_poiPriority >= 1 and not na(amyDashV2_poiHigh) and not na(amyDashV2_poiLow)
amyContextV4_poiEventRaw = amyContextV4_isM5 and barstate.isconfirmed and amyContextV4_poiFresh and
 (not amyContextV4_poiFresh[1] or amyDashV2_poiType != amyDashV2_poiType[1] or amyDashV2_poiHigh != amyDashV2_poiHigh[1] or amyDashV2_poiLow != amyDashV2_poiLow[1])
amyContextV4_poiOutside = amyContextV4_poiFresh and (low > amyDashV2_poiHigh or high < amyDashV2_poiLow)
amyContextV4_poiDir = amyContextV4_poiOutside ? (close > amyDashV2_poiHigh ? -1 : 1) : 0
amyContextV4_poiCandidate = amyContextV4_poiDir == -1 ? amyDashV2_poiHigh : amyContextV4_poiDir == 1 ? amyDashV2_poiLow : na
amyContextV4_poiDistAtr = amyContextV4_poiDir != 0 and not na(amyEntryV2_atr14) ? math.abs(amyContextV4_poiCandidate - close) / amyEntryV2_atr14 : na
amyContextV4_poiEvent = amyContextV4_poiEventRaw and amyContextV4_poiOutside and not na(amyContextV4_poiDistAtr) and amyContextV4_poiDistAtr <= amyContextV4_poiRevisitMaxAtr
var int amyContextV4_poiState = 0
var int amyContextV4_poiStartBar = na
var int amyContextV4_poiLockedDir = 0
var int amyContextV4_poiLockedType = 0
var float amyContextV4_poiLockedTarget = na
if amyContextV4_poiEvent
    amyContextV4_poiState := 1
    amyContextV4_poiStartBar := bar_index
    amyContextV4_poiLockedDir := amyContextV4_poiDir
    amyContextV4_poiLockedType := amyDashV2_poiType
    amyContextV4_poiLockedTarget := amyContextV4_poiCandidate
else if amyContextV4_poiState == 1
    _poiHit = amyContextV4_poiLockedDir == 1 ? high >= amyContextV4_poiLockedTarget : low <= amyContextV4_poiLockedTarget
    if _poiHit
        amyContextV4_poiState := 2
    else if bar_index - amyContextV4_poiStartBar >= amyContextV4_fourHoursBars
        amyContextV4_poiState := 3
amyContextV4_poiActive = amyContextV4_poiState == 1

// --- Validated Asia entry: close entry, nearest Asia TP, fixed 0.20 reward:risk ---
amyContextV4_asiaEntryEvent = amyContextV4_midnightEvent and amyContextV4_asiaDir != 0 and not na(amyContextV4_asiaDistAtr) and
 amyContextV4_asiaDistAtr >= amyContextV4_asiaEntryMinAtr and amyContextV4_asiaDistAtr <= amyContextV4_asiaEntryMaxAtr
var int amyContextV4_asiaEntryState = 0  // 1 active, 2 TP, 3 SL, 4 timeout
var int amyContextV4_asiaEntryStartBar = na
var int amyContextV4_asiaEntryDir = 0
var float amyContextV4_asiaEntryPrice = na
var float amyContextV4_asiaEntryTarget = na
var float amyContextV4_asiaEntryStop = na
if amyContextV4_asiaEntryEvent
    _entryReward = math.abs(amyContextV4_asiaCandidate - close)
    amyContextV4_asiaEntryState := 1
    amyContextV4_asiaEntryStartBar := bar_index
    amyContextV4_asiaEntryDir := amyContextV4_asiaDir
    amyContextV4_asiaEntryPrice := close
    amyContextV4_asiaEntryTarget := amyContextV4_asiaCandidate
    amyContextV4_asiaEntryStop := close - amyContextV4_asiaDir * (_entryReward / amyContextV4_asiaEntryRewardRisk)
else if amyContextV4_asiaEntryState == 1
    _entryStopHit = amyContextV4_asiaEntryDir == 1 ? low <= amyContextV4_asiaEntryStop : high >= amyContextV4_asiaEntryStop
    _entryTargetHit = amyContextV4_asiaEntryDir == 1 ? high >= amyContextV4_asiaEntryTarget : low <= amyContextV4_asiaEntryTarget
    if _entryStopHit
        amyContextV4_asiaEntryState := 3
    else if _entryTargetHit
        amyContextV4_asiaEntryState := 2
    else if bar_index - amyContextV4_asiaEntryStartBar >= amyContextV4_fourHoursBars
        amyContextV4_asiaEntryState := 4
amyContextV4_asiaEntryActive = amyContextV4_asiaEntryState == 1
amyContextV4_asiaEntryTpEvent = amyContextV4_asiaEntryState == 2 and amyContextV4_asiaEntryState[1] == 1
amyContextV4_asiaEntrySlEvent = amyContextV4_asiaEntryState == 3 and amyContextV4_asiaEntryState[1] == 1
amyContextV4_asiaEntryTimeoutEvent = amyContextV4_asiaEntryState == 4 and amyContextV4_asiaEntryState[1] == 1

// Valid break conditions
amyEntryV2_validBreakBull = amyEntryV2_ltfBullBreak and amyEntryV2_ltfBullDisp and amyDashV2_biasDir == 1
amyEntryV2_validBreakBear = amyEntryV2_ltfBearBreak and amyEntryV2_ltfBearDisp and amyDashV2_biasDir == -1

// =====================================================================
// CONTEXTUAL NARRATION ENGINE
// Chart "berbicara" — menjelaskan apa yang terjadi dengan harga
// secara natural, seperti asisten trading pribadi
// =====================================================================

amyEntryV2_addLine(_existing, _new) =>
    _existing == "" ? _new : _existing + "\n" + _new

// === Compose contextual narration ===
amyEntryV2_liveText = ""
amyEntryV2_liveDir = amyEntryV2_winDir != 0 ? amyEntryV2_winDir : (amyDashV2_biasDir != 0 ? amyDashV2_biasDir : 1)
amyEntryV2_liveBg = color.new(color.gray, 15)

if amyEntryV2_show
    // --- PRIORITAS 1: Setup batal / Invalid ---
    if amyDashV2_invalidStatus == 2
        amyEntryV2_liveText := "⚠ Setup batal\nHarga melewati invalid " + amyEntryV2_price(amyDashV2_invalidLevel) + "\nJangan entry, tunggu struktur baru"
        amyEntryV2_liveDir := amyDashV2_biasDir == 0 ? -1 : amyDashV2_biasDir
        amyEntryV2_liveBg := color.new(#b71c1c, 5)

    else
        // === Build narration dari semua event yang aktif ===
        _narr = ""
        _importance = 0  // track how important current state is

        // --- Only locked validated states below may make a forward-looking claim ---
        if amyEntryV3_validatedRisk
            _narr := amyEntryV2_addLine(_narr, "⚠ VALIDATED RISK")
            _narr := amyEntryV2_addLine(_narr, "Struktur M15 berisiko invalid/berubah ≤4 jam")
            _narr := amyEntryV2_addLine(_narr, "Level invalid @ " + amyEntryV2_price(amyDashV2_invalidLevel))
            _narr := amyEntryV2_addLine(_narr, "Backtest 2020-2025: 85.55%")
            _importance := 5

        else if amyContextV4_asiaEntryTpEvent
            _narr := amyEntryV2_addLine(_narr, "✅ ASIA ENTRY TP")
            _narr := amyEntryV2_addLine(_narr, "Target " + amyEntryV2_price(amyContextV4_asiaEntryTarget) + " tercapai")
            _importance := 4

        else if amyContextV4_asiaEntrySlEvent
            _narr := amyEntryV2_addLine(_narr, "✕ ASIA ENTRY SL")
            _narr := amyEntryV2_addLine(_narr, "Stop " + amyEntryV2_price(amyContextV4_asiaEntryStop) + " tersentuh")
            _importance := 4

        else if amyContextV4_asiaEntryTimeoutEvent
            _narr := amyEntryV2_addLine(_narr, "⌛ ASIA ENTRY TIMEOUT")
            _narr := amyEntryV2_addLine(_narr, "Empat jam selesai tanpa TP/SL")
            _importance := 3

        else if amyContextV4_asiaEntryActive
            _narr := amyEntryV2_addLine(_narr, "✅ VALIDATED ASIA ENTRY")
            _narr := amyEntryV2_addLine(_narr, amyEntryV2_dirName(amyContextV4_asiaEntryDir) + " @ " + amyEntryV2_price(amyContextV4_asiaEntryPrice))
            _narr := amyEntryV2_addLine(_narr, "TP " + amyEntryV2_price(amyContextV4_asiaEntryTarget) + " | SL " + amyEntryV2_price(amyContextV4_asiaEntryStop))
            _narr := amyEntryV2_addLine(_narr, "WR 84.70% | Reward:Risk 0.20 | gross, biaya belum dihitung")
            _importance := 5

        else if amyEntryV3_validatedTarget
            _narr := amyEntryV2_addLine(_narr, "✅ VALIDATED TARGET")
            _narr := amyEntryV2_addLine(_narr, amyEntryV2_dolName(amyDashV2_dolDir) + " @ " + amyEntryV2_price(amyDashV2_dolTarget))
            _narr := amyEntryV2_addLine(_narr, "Backtest target-reach 2020-2025: 91.38%")
            _importance := 5

        else if amyContextV4_asiaTargetActive
            _narr := amyEntryV2_addLine(_narr, "✅ VALIDATED ASIA TARGET")
            _narr := amyEntryV2_addLine(_narr, (amyContextV4_asiaTargetLockedDir == 1 ? "ASIA H" : "ASIA L") + " @ " + amyEntryV2_price(amyContextV4_asiaTargetLockedPrice))
            _narr := amyEntryV2_addLine(_narr, "Target-reach ≤4 jam: 86.64%")
            _importance := 4

        else if amyContextV4_pdhPdlActive
            _narr := amyEntryV2_addLine(_narr, "✅ VALIDATED PREVIOUS-DAY TARGET")
            _narr := amyEntryV2_addLine(_narr, (amyContextV4_pdhPdlLockedDir == 1 ? "PDH" : "PDL") + " @ " + amyEntryV2_price(amyContextV4_pdhPdlLockedTarget))
            _narr := amyEntryV2_addLine(_narr, "Target-reach ≤8 jam: 85.64%")
            _importance := 4

        else if amyContextV4_moActive
            _narr := amyEntryV2_addLine(_narr, "✅ VALIDATED MIDNIGHT-OPEN RETEST")
            _narr := amyEntryV2_addLine(_narr, "MO @ " + amyEntryV2_price(amyContextV4_moLockedTarget))
            _narr := amyEntryV2_addLine(_narr, "Retest ≤4 jam: 86.43%")
            _importance := 4

        else if amyContextV4_poiActive
            _poiClaimName = math.abs(amyContextV4_poiLockedType) == 1 ? "ORDER BLOCK" : "FVG"
            _poiClaimAccuracy = math.abs(amyContextV4_poiLockedType) == 1 ? "83.91%" : "82.37%"
            _narr := amyEntryV2_addLine(_narr, "✅ VALIDATED " + _poiClaimName + " REVISIT")
            _narr := amyEntryV2_addLine(_narr, "POI @ " + amyEntryV2_price(amyContextV4_poiLockedTarget))
            _narr := amyEntryV2_addLine(_narr, "Revisit ≤4 jam: " + _poiClaimAccuracy)
            _importance := 4

        else if amyContextV4_keyLiquidityActive
            _narr := amyEntryV2_addLine(_narr, "✅ VALIDATED M5 LIQUIDITY TARGET")
            _narr := amyEntryV2_addLine(_narr, (amyContextV4_keyLiquidityLockedDir == 1 ? "BSL" : "SSL") + " @ " + amyEntryV2_price(amyContextV4_keyLiquidityLockedTarget))
            _narr := amyEntryV2_addLine(_narr, "Target-reach ≤4 jam: 82.43%")
            _importance := 4

        else if amyContextV4_protectedActive
            _protectedName = amyContextV4_protectedDir == 1 ? "PROTECTED LOW" : "PROTECTED HIGH"
            _protectedAccuracy = amyContextV4_protectedDir == 1 ? "93.47%" : "91.86%"
            _narr := amyEntryV2_addLine(_narr, "✅ VALIDATED " + _protectedName)
            _narr := amyEntryV2_addLine(_narr, "Level @ " + amyEntryV2_price(amyContextV4_protectedLevel))
            _narr := amyEntryV2_addLine(_narr, "Diperkirakan bertahan 1 jam: " + _protectedAccuracy)
            _importance := 4

        // --- POI Rejection (descriptive, not an entry confirmation) ---
        else if amyEntryV2_bullPoiReject
            _narr := amyEntryV2_addLine(_narr, "🔥 Rejection kuat dari " + amyEntryV2_poiName(amyDashV2_poiType))
            _narr := amyEntryV2_addLine(_narr, "Reaksi bullish; bukan sinyal entry mandiri")
            _importance := 2
        else if amyEntryV2_bearPoiReject
            _narr := amyEntryV2_addLine(_narr, "🔥 Rejection kuat dari " + amyEntryV2_poiName(amyDashV2_poiType))
            _narr := amyEntryV2_addLine(_narr, "Reaksi bearish; bukan sinyal entry mandiri")
            _importance := 2

        // --- Valid Break + Displacement ---
        else if amyEntryV2_validBreakBull
            _narr := amyEntryV2_addLine(_narr, "✓ Valid break bullish dengan displacement")
            _narr := amyEntryV2_addLine(_narr, "Struktur LTF naik; belum tervalidasi untuk entry")
            _importance := 2
        else if amyEntryV2_validBreakBear
            _narr := amyEntryV2_addLine(_narr, "✓ Valid break bearish dengan displacement")
            _narr := amyEntryV2_addLine(_narr, "Struktur LTF turun; belum tervalidasi untuk entry")
            _importance := 2

        // --- Harga masuk POI ---
        else if amyEntryV2_inPoi
            _poiN = amyEntryV2_poiName(amyDashV2_poiType)
            _narr := amyEntryV2_addLine(_narr, "📍 " + _poiN + " tersentuh")
            _narr := amyEntryV2_addLine(_narr, "Pantau reaksi harga di zona ini")
            if amyDashV2_biasDir == 1
                _narr := amyEntryV2_addLine(_narr, "Amati rejection bullish; belum menjadi sinyal")
            else if amyDashV2_biasDir == -1
                _narr := amyEntryV2_addLine(_narr, "Amati rejection bearish; belum menjadi sinyal")
            _importance := 2

        // --- Harga mendekati POI ---
        else if amyEntryV2_nearPoi
            _poiN = amyEntryV2_poiName(amyDashV2_poiType)
            _narr := amyEntryV2_addLine(_narr, "👀 Harga mendekati " + _poiN)
            _narr := amyEntryV2_addLine(_narr, "Jarak zona dekat; observasi saja")
            _importance := 2

        // --- LTF Sweep aligned ---
        else if amyEntryV2_ltfSweepAligned
            if amyEntryV2_ltfSweepDir == 1
                _narr := amyEntryV2_addLine(_narr, "💧 SSL swept di LTF")
                _narr := amyEntryV2_addLine(_narr, "Likuiditas bawah terambil; amati respons")
            else
                _narr := amyEntryV2_addLine(_narr, "💧 BSL swept di LTF")
                _narr := amyEntryV2_addLine(_narr, "Likuiditas atas terambil; amati respons")
            _importance := 2

        // --- M15 Sweep fresh ---
        else if amyDashV2_sweepStatus == 1 and amyDashV2_sweepDir != 0
            if amyDashV2_sweepDir == 1
                _narr := amyEntryV2_addLine(_narr, "💧 SSL swept (fresh)")
                _narr := amyEntryV2_addLine(_narr, "Konteks bullish mentah; belum menjadi sinyal")
            else
                _narr := amyEntryV2_addLine(_narr, "💧 BSL swept (fresh)")
                _narr := amyEntryV2_addLine(_narr, "Konteks bearish mentah; belum menjadi sinyal")
            _importance := 2

        // --- LTF Displacement only ---
        else if amyEntryV2_ltfBullDisp and amyDashV2_biasDir == 1
            _narr := amyEntryV2_addLine(_narr, "⚡ Displacement bullish terdeteksi")
            _narr := amyEntryV2_addLine(_narr, "Candle momentum kuat ke atas")
            _importance := 2
        else if amyEntryV2_ltfBearDisp and amyDashV2_biasDir == -1
            _narr := amyEntryV2_addLine(_narr, "⚡ Displacement bearish terdeteksi")
            _narr := amyEntryV2_addLine(_narr, "Candle momentum kuat ke bawah")
            _importance := 2

        // --- DOL terminal events ---
        else if amyEntryV2_dolInvalidEvent
            _narr := amyEntryV2_addLine(_narr, "⚠ DOL invalid")
            _narr := amyEntryV2_addLine(_narr, "Harga close melewati sweep extreme")
            _importance := 2
        else if amyEntryV2_dolAbandonedEvent
            _narr := amyEntryV2_addLine(_narr, "↪ DOL ditinggalkan")
            _narr := amyEntryV2_addLine(_narr, "Bias M15 berubah, target lama tidak lagi relevan")
            _importance := 1
        else if amyEntryV2_dolExpiredEvent
            _narr := amyEntryV2_addLine(_narr, "⌛ DOL expired")
            _narr := amyEntryV2_addLine(_narr, "Target tidak tercapai dalam freshness window")
            _importance := 1
        else if amyEntryV2_dolReachedEvent
            _narr := amyEntryV2_addLine(_narr, "🎯 Target " + amyEntryV2_dolName(amyDashV2_dolDir) + " tercapai")
            _narr := amyEntryV2_addLine(_narr, "Hati-hati reaksi baru, jangan kejar harga")
            _importance := 2

        // --- DOL active near target ---
        else if amyEntryV2_nearDol
            _narr := amyEntryV2_addLine(_narr, "🎯 Harga mendekati target " + amyEntryV2_dolName(amyDashV2_dolDir))
            _narr := amyEntryV2_addLine(_narr, amyEntryV2_dolName(amyDashV2_dolDir) + " @ " + amyEntryV2_price(amyDashV2_dolTarget))
            _narr := amyEntryV2_addLine(_narr, "Belum lolos filter validasi")
            _importance := 2

        // --- DOL active far ---
        else if amyDashV2_dolStatus == 1
            _narr := amyEntryV2_addLine(_narr, "DOL aktif tetapi belum lolos filter validasi")
            _narr := amyEntryV2_addLine(_narr, amyEntryV2_dolName(amyDashV2_dolDir) + " @ " + amyEntryV2_price(amyDashV2_dolTarget))
            _importance := 1

        // --- Bias info jika tidak ada event spesifik ---
        else if amyDashV2_biasDir == 1
            _narr := amyEntryV2_addLine(_narr, "Struktur M15: Bullish (deskriptif)")
            _narr := amyEntryV2_addLine(_narr, "Bukan prediksi arah atau sinyal entry")
            _importance := 1
        else if amyDashV2_biasDir == -1
            _narr := amyEntryV2_addLine(_narr, "Struktur M15: Bearish (deskriptif)")
            _narr := amyEntryV2_addLine(_narr, "Bukan prediksi arah atau sinyal entry")
            _importance := 1

        // === Tambahan konteks (layer 2) ===

        // Raw Near Invalid that failed the locked V3 filter remains observation-only.
        if amyDashV2_invalidStatus == 1 and not amyEntryV3_validatedRisk
            _narr := amyEntryV2_addLine(_narr, "⚪ Near Invalid mentah — belum tervalidasi")

        // Asia level interactions
        if amyEntryV2_breakAboveAsiaH
            _narr := amyEntryV2_addLine(_narr, "Asia High break ke atas ↑")
        else if amyEntryV2_breakBelowAsiaL
            _narr := amyEntryV2_addLine(_narr, "Asia Low break ke bawah ↓")
        else if amyEntryV2_touchAsiaH and not amyEntryV2_touchAsiaL
            _narr := amyEntryV2_addLine(_narr, "Harga menyentuh Asia High")
        else if amyEntryV2_touchAsiaL and not amyEntryV2_touchAsiaH
            _narr := amyEntryV2_addLine(_narr, "Harga menyentuh Asia Low")
        else if amyEntryV2_nearAsiaH and close < amyKeyV2_asiaHigh
            _narr := amyEntryV2_addLine(_narr, "Harga mendekati Asia High")
        else if amyEntryV2_nearAsiaL and close > amyKeyV2_asiaLow
            _narr := amyEntryV2_addLine(_narr, "Harga mendekati Asia Low")

        // Price zone context
        if amyDashV2_priceZone == -1 and amyDashV2_biasDir == 1
            _narr := amyEntryV2_addLine(_narr, "📊 Discount dalam struktur bullish (observasi)")
        else if amyDashV2_priceZone == 1 and amyDashV2_biasDir == -1
            _narr := amyEntryV2_addLine(_narr, "📊 Premium dalam struktur bearish (observasi)")
        else if amyDashV2_priceZone == 1 and amyDashV2_biasDir == 1
            _narr := amyEntryV2_addLine(_narr, "📊 Posisi di Premium — bukan zona ideal buy")
        else if amyDashV2_priceZone == -1 and amyDashV2_biasDir == -1
            _narr := amyEntryV2_addLine(_narr, "📊 Posisi di Discount — bukan zona ideal sell")

        // Target info
        if amyEntryV3_validatedTarget and not amyEntryV2_nearDol and _importance >= 2
            _narr := amyEntryV2_addLine(_narr, "Target → " + amyEntryV2_dolName(amyDashV2_dolDir) + " " + amyEntryV2_price(amyDashV2_dolTarget))

        // A validated DOL uses its locked sweep extreme, not the raw-bias invalid level.
        if amyEntryV3_validatedTarget and not na(amyDashV2_sweepExtreme)
            _narr := amyEntryV2_addLine(_narr, "DOL invalid jika close " + (amyDashV2_dolDir == 1 ? "di bawah " : "di atas ") + amyEntryV2_price(amyDashV2_sweepExtreme))

        // Score indicator kecil di akhir
        if amyEntryV2_winScore >= amyEntryV2_minScore
            _scoreEmoji = amyEntryV3_validatedTarget or amyEntryV3_validatedRisk or amyContextV4_asiaEntryActive or amyContextV4_asiaTargetActive or amyContextV4_pdhPdlActive or amyContextV4_moActive or amyContextV4_poiActive or amyContextV4_keyLiquidityActive or amyContextV4_protectedActive ? "✅" : "⚪"
            _narr := amyEntryV2_addLine(_narr, _scoreEmoji + " Context score " + str.tostring(amyEntryV2_winScore) + "/100")

        // Assign text & colors
        if _narr != ""
            amyEntryV2_liveText := _narr
            amyEntryV2_liveDir := amyEntryV3_validatedRisk ? (amyDashV2_biasDir == 1 ? -1 : 1) : amyContextV4_asiaEntryActive ? amyContextV4_asiaEntryDir : amyEntryV3_validatedTarget ? amyDashV2_dolDir : amyContextV4_asiaTargetActive ? amyContextV4_asiaTargetLockedDir : amyContextV4_pdhPdlActive ? amyContextV4_pdhPdlLockedDir : amyContextV4_moActive ? amyContextV4_moLockedDir : amyContextV4_poiActive ? amyContextV4_poiLockedDir : amyContextV4_keyLiquidityActive ? amyContextV4_keyLiquidityLockedDir : amyContextV4_protectedActive ? amyContextV4_protectedDir : amyEntryV2_winDir != 0 ? amyEntryV2_winDir : amyDashV2_biasDir != 0 ? amyDashV2_biasDir : 1

            // Warna berdasarkan importance + direction
            if amyEntryV3_validatedRisk
                amyEntryV2_liveBg := color.new(#ef6c00, 0)
            else if _importance >= 4
                amyEntryV2_liveBg := amyEntryV2_liveDir == 1 ? color.new(#00c853, 0) : color.new(#d50000, 0)
            else if _importance >= 3
                amyEntryV2_liveBg := amyEntryV2_liveDir == 1 ? color.new(#00c853, 15) : color.new(#d50000, 15)
            else if _importance >= 2
                amyEntryV2_liveBg := amyEntryV2_liveDir == 1 ? color.new(#1b5e20, 20) : color.new(#b71c1c, 20)
            else
                amyEntryV2_liveBg := color.new(#37474f, 15)


// === Assistant V4 claim markers ===
// The former Strong/Ready markers were removed because their out-of-sample accuracy was below 80%.
// Each marker is emitted once, only when a new claim passes its locked validation filter.
amyEntryV2_validatedBullEvent = amyEntryV2_show and amyEntryV2_showValidatedMarkers and amyEntryV3_validatedTargetEvent and amyDashV2_dolDir == 1
amyEntryV2_validatedBearEvent = amyEntryV2_show and amyEntryV2_showValidatedMarkers and amyEntryV3_validatedTargetEvent and amyDashV2_dolDir == -1
amyEntryV3_riskEvent = amyEntryV2_show and amyEntryV2_showValidatedMarkers and amyEntryV3_validatedRiskEvent
amyContextV4_showMarker = amyEntryV2_show and amyEntryV2_showValidatedMarkers

plotshape(amyEntryV2_validatedBullEvent and barstate.isconfirmed ? low : na, title="Validated DOL Up", style=shape.triangleup, location=location.belowbar, color=color.new(#00c853, 0), size=size.small, text="DOL✓")
plotshape(amyEntryV2_validatedBearEvent and barstate.isconfirmed ? high : na, title="Validated DOL Down", style=shape.triangledown, location=location.abovebar, color=color.new(#d50000, 0), size=size.small, text="DOL✓")
plotshape(amyEntryV3_riskEvent and barstate.isconfirmed ? high : na, title="Validated Structure Risk", style=shape.xcross, location=location.abovebar, color=color.new(#ff6d00, 0), size=size.small, text="RISK✓")
plotshape(amyContextV4_showMarker and amyContextV4_protectedEvent and amyDashV2_biasDir == 1 ? low : na, title="Validated Protected Low 1H", style=shape.circle, location=location.belowbar, color=color.new(#00bfa5, 0), size=size.tiny, text="P-L✓")
plotshape(amyContextV4_showMarker and amyContextV4_protectedEvent and amyDashV2_biasDir == -1 ? high : na, title="Validated Protected High 1H", style=shape.circle, location=location.abovebar, color=color.new(#00bfa5, 0), size=size.tiny, text="P-H✓")
plotshape(amyContextV4_showMarker and amyContextV4_keyLiquidityEvent and amyContextV4_keyLiquidityDir == 1 ? low : na, title="Validated M5 BSL Target", style=shape.circle, location=location.belowbar, color=color.new(#aa00ff, 0), size=size.tiny, text="BSL✓")
plotshape(amyContextV4_showMarker and amyContextV4_keyLiquidityEvent and amyContextV4_keyLiquidityDir == -1 ? high : na, title="Validated M5 SSL Target", style=shape.circle, location=location.abovebar, color=color.new(#00b8d4, 0), size=size.tiny, text="SSL✓")
plotshape(amyContextV4_showMarker and amyContextV4_pdhPdlEvent and amyContextV4_pdhPdlDir == 1 ? low : na, title="Validated PDH Target", style=shape.circle, location=location.belowbar, color=color.new(#ff1744, 0), size=size.tiny, text="PDH✓")
plotshape(amyContextV4_showMarker and amyContextV4_pdhPdlEvent and amyContextV4_pdhPdlDir == -1 ? high : na, title="Validated PDL Target", style=shape.circle, location=location.abovebar, color=color.new(#76ff03, 0), size=size.tiny, text="PDL✓")
plotshape(amyContextV4_showMarker and amyContextV4_asiaTargetEvent and amyContextV4_asiaDir == 1 ? low : na, title="Validated Asia High Target", style=shape.circle, location=location.belowbar, color=color.new(#ff6d00, 0), size=size.tiny, text="AH✓")
plotshape(amyContextV4_showMarker and amyContextV4_asiaTargetEvent and amyContextV4_asiaDir == -1 ? high : na, title="Validated Asia Low Target", style=shape.circle, location=location.abovebar, color=color.new(#00b0ff, 0), size=size.tiny, text="AL✓")
plotshape(amyContextV4_showMarker and amyContextV4_moEvent and amyContextV4_moDir == 1 ? low : na, title="Validated Midnight Open Retest Up", style=shape.circle, location=location.belowbar, color=color.new(color.yellow, 0), size=size.tiny, text="MO✓")
plotshape(amyContextV4_showMarker and amyContextV4_moEvent and amyContextV4_moDir == -1 ? high : na, title="Validated Midnight Open Retest Down", style=shape.circle, location=location.abovebar, color=color.new(color.yellow, 0), size=size.tiny, text="MO✓")
plotshape(amyContextV4_showMarker and amyContextV4_poiEvent and math.abs(amyDashV2_poiType) == 1 ? close : na, title="Validated Order Block Revisit", style=shape.circle, location=location.absolute, color=color.new(#2962ff, 0), size=size.tiny, text="OB✓")
plotshape(amyContextV4_showMarker and amyContextV4_poiEvent and math.abs(amyDashV2_poiType) == 2 ? close : na, title="Validated FVG Revisit", style=shape.circle, location=location.absolute, color=color.new(#00c853, 0), size=size.tiny, text="FVG✓")
plotshape(amyContextV4_showMarker and amyContextV4_asiaEntryEvent ? close : na, title="Validated Asia Entry", style=shape.diamond, location=location.absolute, color=color.new(#ffd600, 0), size=size.small, text="ENTRY✓")
plotshape(amyContextV4_showMarker and amyContextV4_asiaEntryTpEvent ? close : na, title="Validated Asia Entry TP", style=shape.flag, location=location.absolute, color=color.new(#00c853, 0), size=size.tiny, text="TP✓")
plotshape(amyContextV4_showMarker and amyContextV4_asiaEntrySlEvent ? close : na, title="Validated Asia Entry SL", style=shape.xcross, location=location.absolute, color=color.new(#d50000, 0), size=size.tiny, text="SL×")

// === Live label on chart ===
var label amyEntryV2_liveLabel = na

amyEntryV2_labelY = amyEntryV2_liveDir == 1 ? low - ta.atr(14) * amyEntryV2_noteOffsetAtr : high + ta.atr(14) * amyEntryV2_noteOffsetAtr
amyEntryV2_labelStyle = amyEntryV2_liveDir == 1 ? label.style_label_up : label.style_label_down

if barstate.islast
    if amyEntryV2_show and amyEntryV2_showChartNotes and amyEntryV2_liveText != ""
        if na(amyEntryV2_liveLabel)
            amyEntryV2_liveLabel := label.new(bar_index, amyEntryV2_labelY, amyEntryV2_liveText, xloc=xloc.bar_index, style=amyEntryV2_labelStyle, color=amyEntryV2_liveBg, textcolor=color.white, size=size.tiny)
        else
            label.set_xy(amyEntryV2_liveLabel, bar_index, amyEntryV2_labelY)
            label.set_text(amyEntryV2_liveLabel, amyEntryV2_liveText)
            label.set_style(amyEntryV2_liveLabel, amyEntryV2_labelStyle)
            label.set_color(amyEntryV2_liveLabel, amyEntryV2_liveBg)
            label.set_textcolor(amyEntryV2_liveLabel, color.white)
            label.set_size(amyEntryV2_liveLabel, size.tiny)
    else
        if not na(amyEntryV2_liveLabel)
            label.delete(amyEntryV2_liveLabel)
            amyEntryV2_liveLabel := na

amyContextV4_anyTargetActive = amyContextV4_asiaTargetActive or amyContextV4_pdhPdlActive or amyContextV4_moActive or amyContextV4_poiActive or amyContextV4_keyLiquidityActive

// The dashboard is created before the assistant validation states exist, so overwrite relevant rows here.
if amyDashV2_show and barstate.islast
    _protectedRole = amyDashV2_biasDir == 1 ? "P-LOW" : amyDashV2_biasDir == -1 ? "P-HIGH" : "REFERENCE"
    _protectedValidation = not amyContextV4_isM5 ? "M5 VALIDATION ONLY" : amyContextV4_protectedActive ? (_protectedRole + " VALID 1H " + (amyDashV2_biasDir == 1 ? "93.47%" : "91.86%")) : "REFERENCE ONLY"
    table.cell(amyDashV2_table, 1, 3, "H " + amyDashV2_price(amyDashV2_protectedHigh) + " | L " + amyDashV2_price(amyDashV2_protectedLow) + " | " + _protectedValidation, text_color=color.white, bgcolor=amyContextV4_protectedActive ? amyDashV2_buyBg : amyDashV2_cellBg, text_size=size.tiny)
    _dashDolState = amyDashV2_dolStatus == 1 ? (amyEntryV3_validatedTarget ? "VALIDATED TARGET" : "OBSERVATION ONLY") : amyDashV2_dolStatusText
    _dashDolBg = amyEntryV3_validatedTarget ? (amyDashV2_dolDir == 1 ? amyDashV2_buyBg : amyDashV2_sellBg) : amyDashV2_dolStatus == 1 ? amyDashV2_neutralBg : amyDashV2_dolBg
    table.cell(amyDashV2_table, 1, 7, amyDashV2_dolText + " @ " + amyDashV2_price(amyDashV2_dolTarget) + " | " + _dashDolState, text_color=color.white, bgcolor=_dashDolBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 8, "Dist " + amyDashV2_price(amyDashV2_dolDistance) + " | Score " + str.tostring(amyEntryV2_dolDirectionScore) + " | " + amyDashV2_dolAlignText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

// === Assistant Panel (optional table) ===
amyEntryV2_panelPos() =>
    amyDashV2_posInput == "Bottom Left" ? position.bottom_right : position.bottom_left

var table amyEntryV2_panel = table.new(position.bottom_left, 2, 10, bgcolor=color.new(color.black, 5), border_width=1, border_color=color.new(color.gray, 55))

if amyEntryV2_show and amyEntryV2_showPanel and barstate.islast
    table.set_position(amyEntryV2_panel, amyEntryV2_panelPos())
    table.clear(amyEntryV2_panel, 0, 0, 1, 9)

    _panelHeadBg = color.new(#07111D, 0)
    _panelKeyBg = color.new(#0B1623, 0)
    _panelCellBg = color.new(#050B12, 0)
    _scoreBg = amyEntryV3_validatedRisk ? color.new(#ff6f00, 10) :
     amyContextV4_asiaEntryActive ? color.new(#ffd600, 20) :
     amyEntryV3_validatedTarget ? (amyDashV2_dolDir == 1 ? color.new(#00c853, 15) : color.new(#d50000, 15)) :
     amyContextV4_anyTargetActive or amyContextV4_protectedActive ? color.new(#00b8d4, 25) :
     color.new(color.gray, 55)

    _panelSignal = amyEntryV3_validatedRisk ? "VALIDATED RISK" : amyContextV4_asiaEntryActive ? "VALIDATED ENTRY" : amyEntryV3_validatedTarget ? "VALIDATED DOL" : amyContextV4_anyTargetActive ? "VALIDATED CONTEXT" : amyContextV4_protectedActive ? "PROTECTED 1H" : "OBSERVATION ONLY"
    table.cell(amyEntryV2_panel, 0, 0, "ASSISTANT V4", text_color=color.white, bgcolor=_panelHeadBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 0, _panelSignal, text_color=color.white, bgcolor=_scoreBg, text_size=size.tiny)

    table.cell(amyEntryV2_panel, 0, 1, "DOL SCORE", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 1, amyDashV2_dolStatus == 1 ? amyEntryV2_dirName(amyDashV2_dolDir) + " " + str.tostring(amyEntryV2_dolDirectionScore) + "/100" : "NO ACTIVE DOL", text_color=color.white, bgcolor=_scoreBg, text_size=size.tiny)

    table.cell(amyEntryV2_panel, 0, 2, "BIAS (20)", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 2, "B:" + str.tostring(amyEntryV2_bullBias) + " | S:" + str.tostring(amyEntryV2_bearBias), text_color=color.white, bgcolor=_panelCellBg, text_size=size.tiny)

    table.cell(amyEntryV2_panel, 0, 3, "SWEEP (20)", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 3, "B:" + str.tostring(amyEntryV2_bullSweep) + " | S:" + str.tostring(amyEntryV2_bearSweep), text_color=color.white, bgcolor=_panelCellBg, text_size=size.tiny)

    table.cell(amyEntryV2_panel, 0, 4, "POI (10+5)", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 4, "B:" + str.tostring(amyEntryV2_bullPoi + amyEntryV2_bullPoiBonus) + " | S:" + str.tostring(amyEntryV2_bearPoi + amyEntryV2_bearPoiBonus), text_color=color.white, bgcolor=_panelCellBg, text_size=size.tiny)

    table.cell(amyEntryV2_panel, 0, 5, "DOL (10)", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 5, "B:" + str.tostring(amyEntryV2_bullDol) + " | S:" + str.tostring(amyEntryV2_bearDol), text_color=color.white, bgcolor=_panelCellBg, text_size=size.tiny)

    table.cell(amyEntryV2_panel, 0, 6, "ZONE (10)", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 6, "B:" + str.tostring(amyEntryV2_bullLoc) + " | S:" + str.tostring(amyEntryV2_bearLoc), text_color=color.white, bgcolor=_panelCellBg, text_size=size.tiny)

    table.cell(amyEntryV2_panel, 0, 7, "LTF (25)", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 7, "B:" + str.tostring(amyEntryV2_bullDisp + amyEntryV2_bullBreak) + " | S:" + str.tostring(amyEntryV2_bearDisp + amyEntryV2_bearBreak), text_color=color.white, bgcolor=_panelCellBg, text_size=size.tiny)

    table.cell(amyEntryV2_panel, 0, 8, "ASIA (5)", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 8, "B:" + str.tostring(amyEntryV2_bullAsia) + " | S:" + str.tostring(amyEntryV2_bearAsia), text_color=color.white, bgcolor=_panelCellBg, text_size=size.tiny)

    _panelTarget = amyContextV4_asiaEntryActive ? amyEntryV2_price(amyContextV4_asiaEntryTarget) : amyEntryV3_validatedTarget and not na(amyDashV2_dolTarget) ? amyEntryV2_price(amyDashV2_dolTarget) : amyContextV4_asiaTargetActive ? amyEntryV2_price(amyContextV4_asiaTargetLockedPrice) : amyContextV4_pdhPdlActive ? amyEntryV2_price(amyContextV4_pdhPdlLockedTarget) : amyContextV4_moActive ? amyEntryV2_price(amyContextV4_moLockedTarget) : amyContextV4_poiActive ? amyEntryV2_price(amyContextV4_poiLockedTarget) : amyContextV4_keyLiquidityActive ? amyEntryV2_price(amyContextV4_keyLiquidityLockedTarget) : "-"
    _panelStop = amyContextV4_asiaEntryActive ? amyEntryV2_price(amyContextV4_asiaEntryStop) : not na(amyDashV2_invalidLevel) ? amyEntryV2_price(amyDashV2_invalidLevel) : "-"
    table.cell(amyEntryV2_panel, 0, 9, "TARGET / STOP", text_color=color.white, bgcolor=_panelKeyBg, text_size=size.tiny)
    table.cell(amyEntryV2_panel, 1, 9, "T: " + _panelTarget + " | S: " + _panelStop, text_color=color.white, bgcolor=_panelCellBg, text_size=size.tiny)

if (not amyEntryV2_show or not amyEntryV2_showPanel) and barstate.islast
    table.clear(amyEntryV2_panel, 0, 0, 1, 9)
